@{
    ViewData["Title"] = "Reporte de Solicitudes";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="psa-page-header">
    <div>
        <span class="subtitle">Reportes</span>
        <h1>Reporte de Solicitudes</h1>
        <p>Estado de todas las solicitudes al programa PSA</p>
    </div>
    <a asp-controller="Reportes" asp-action="Index" class="btn btn-outline-psa btn-sm"><i class="fas fa-arrow-left"></i> Volver</a>
</div>

<div class="psa-card">
    <div class="psa-card-header">
        <div class="psa-card-title"><i class="fas fa-file-lines"></i> Solicitudes Registradas</div>
    </div>
    <div id="gridReporteSolicitudes" style="height:300px;width:100%;" class="ag-theme-alpine"></div>
</div>

@section Scripts {
    <script src="~/js/Pages/Reportes/SolicitudesReporteGrid.js" asp-append-version="true"></script>
}