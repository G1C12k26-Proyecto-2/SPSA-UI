@{
    ViewData["Title"] = "Historial de Pagos";
    ViewData["Breadcrumb"] = "Historial de Pagos";
}

<div class="psa-page-header">
    <div>
        <span class="subtitle">Mis Pagos</span>
        <h1>Historial de Pagos</h1>
        <p>Registro de todos los pagos PSA recibidos en sus fincas</p>
    </div>
</div>

<!-- STAT CARDS -->
<div class="psa-stats">
    <div class="psa-stat-card">
        <div class="psa-stat-header">
            <div class="psa-stat-label">Total Recibido</div>
            <div class="psa-stat-icon green"><i class="fas fa-circle-dollar-to-slot"></i></div>
        </div>
        <div class="psa-stat-value">₡22.8M</div>
        <div class="psa-stat-sub">Acumulado histórico</div>
    </div>
    <div class="psa-stat-card">
        <div class="psa-stat-header">
            <div class="psa-stat-label">Último Pago</div>
            <div class="psa-stat-icon green"><i class="fas fa-check-circle"></i></div>
        </div>
        <div class="psa-stat-value">₡3.8M</div>
        <div class="psa-stat-sub">10 mar 2026</div>
    </div>
    <div class="psa-stat-card">
        <div class="psa-stat-header">
            <div class="psa-stat-label">Próximo Pago</div>
            <div class="psa-stat-icon gold"><i class="fas fa-calendar-check"></i></div>
        </div>
        <div class="psa-stat-value">₡3.8M</div>
        <div class="psa-stat-sub">15 abr 2026</div>
    </div>
    <div class="psa-stat-card">
        <div class="psa-stat-header">
            <div class="psa-stat-label">Fincas Activas</div>
            <div class="psa-stat-icon blue"><i class="fas fa-tree"></i></div>
        </div>
        <div class="psa-stat-value">2</div>
        <div class="psa-stat-sub">Recibiendo pagos</div>
    </div>
</div>

<!-- TABLA DE PAGOS -->
<div class="psa-card">
    <div class="psa-filters">
        <input type="text" class="form-control form-control-sm" placeholder="Buscar por finca..." style="max-width:220px;" id="historialBusqueda" />
        <select class="form-select form-select-sm" style="max-width:160px;" id="historialEstado">
            <option>Todos los estados</option>
            <option>Ejecutado</option>
            <option>Pendiente</option>
            <option>Rechazado</option>
        </select>
        <select class="form-select form-select-sm" style="max-width:160px;" id="historialFincas">
            <option>Todas las fincas</option>
            <option>Finca La Catarata</option>
            <option>Finca El Roble</option>
        </select>
        <select class="form-select form-select-sm" style="max-width:140px;" id="historialAno">
            <option>2026</option>
            <option>2025</option>
            <option>2024</option>
            <option>2023</option>
        </select>
        <div class="spacer"></div>
        <button class="btn btn-outline-psa btn-sm"><i class="fas fa-download"></i> Exportar</button>
    </div>
    <div id="gridHistorialPagos" style="height:400px;width:100%;" class="ag-theme-alpine"></div>
</div>

@section Scripts {
    <script src="~/js/Pages/Cuenta/HistorialPagosGrid.js" asp-append-version="true"></script>
}
