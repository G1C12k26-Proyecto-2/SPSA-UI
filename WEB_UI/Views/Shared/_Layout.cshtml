@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistema PSA</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/psatheme.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
<div class="psa-layout">
    <!-- SIDEBAR -->
    <aside class="psa-sidebar">
        <div class="psa-sidebar-brand">
            <div class="badge-label">SINAC · FONAFIFO</div>
            <div class="brand-title"><a asp-controller="Fincas" asp-action="Index">Bio<span>Pago</span></a></div>
        </div>
        <div class="psa-sidebar-user">
            <div class="psa-avatar">CF</div>
            <div>
                <div class="user-name">Carlos Fonseca</div>
                <div class="user-role">Dueño de Finca</div>
            </div>
        </div>
        <nav class="psa-sidebar-nav">
            <div class="psa-nav-section">Mis Fincas</div>
            <a class="psa-nav-item @(controller == "Fincas" && action == "Index" ? "active" : "")" asp-controller="Fincas" asp-action="Index">
                <i class="fas fa-tree"></i> Mis Fincas
            </a>
            <a class="psa-nav-item @(controller == "Fincas" && action == "Crear" ? "active" : "")" asp-controller="Fincas" asp-action="Crear">
                <i class="fas fa-file-circle-plus"></i> Registrar Finca
            </a>
                <div class="psa-nav-section Juan2">Solicitudes </div>
                <a class="psa-nav-item Juan2" href="#">
                <i class="fas fa-clock-rotate-left"></i> Mis Solicitudes
            </a>
            <a class="psa-nav-item Juan3" href="#">
                <i class="fas fa-file-lines"></i> Documentos
            </a>
            <div class="psa-nav-section">Pagos</div>
            <a class="psa-nav-item @(controller == "Cuenta" && action == "HistorialPagos" ? "active" : "")" asp-controller="Cuenta" asp-action="HistorialPagos">
                <i class="fas fa-circle-dollar-to-slot"></i> Historial de Pagos
            </a>
            <div class="psa-nav-section">Cuenta</div>
            <a class="psa-nav-item @(controller == "Cuenta" && action == "Perfil" ? "active" : "")" asp-controller="Cuenta" asp-action="Perfil">
                <i class="fas fa-user-circle"></i> Mi Perfil
            </a>
            <a class="psa-nav-item @(controller == "Cuenta" && (action == "DatosBanco" || action == "ActualizarBanco") ? "active" : "")" asp-controller="Cuenta" asp-action="DatosBanco">
                <i class="fas fa-building-columns"></i> Datos Bancarios
            </a>
            <a class="psa-nav-item Jean " href="#">
                <i class="fas fa-bell"></i> Notificaciones
            </a>
        </nav>
        <div class="psa-sidebar-footer">
                <a class="psa-logout" href="#" onclick="cerrarSesion()"><i class="fas fa-right-from-bracket"></i> Cerrar sesión</a>
        </div>
    </aside>

    <!-- MAIN -->
    <div class="psa-main">
        <div class="psa-topbar">
            <div class="psa-breadcrumb">
                <a asp-controller="Fincas" asp-action="Index">Sistema PSA</a>
                <i class="fas fa-chevron-right" style="font-size:0.55rem;"></i>
                <span class="current">@ViewData["Breadcrumb"]</span>
            </div>
            <div class="psa-topbar-right">
                <!-- NOTIFICACIONES DROPDOWN -->
                <div class="psa-notif-wrapper" style="position:relative;">
                    <div class="psa-topbar-icon" id="btnNotif" onclick="toggleNotif()" style="cursor:pointer;">
                        <i class="fas fa-bell"></i>
                        <div class="dot"></div>
                    </div>
                    <!-- PANEL DE NOTIFICACIONES -->
                    <div class="psa-notif-panel" id="notifPanel" style="display:none;position:absolute;top:calc(100% + 8px);right:0;width:360px;background:#fff;border-radius:var(--psa-r);border:1px solid var(--psa-border);box-shadow:0 12px 40px rgba(13,43,26,0.12);z-index:999;overflow:hidden;">
                        <!-- Header -->
                        <div style="padding:0.9rem 1.2rem;border-bottom:1px solid var(--psa-border);display:flex;align-items:center;justify-content:space-between;background:#fefefe;">
                            <div style="font-family:'Fraunces',serif;font-size:0.95rem;font-weight:500;color:var(--psa-forest);display:flex;align-items:center;gap:0.4rem;">
                                <i class="fas fa-bell" style="font-size:0.82rem;color:var(--psa-leaf);"></i> Notificaciones
                            </div>
                            <span style="font-size:0.6rem;font-weight:600;background:var(--psa-pale);color:var(--psa-leaf);padding:0.15rem 0.5rem;border-radius:99px;">3 nuevas</span>
                        </div>
                        <!-- Lista -->
                        <div style="max-height:340px;overflow-y:auto;">
                            <!-- Notif 1 -->
                            <div style="padding:0.9rem 1.2rem;border-bottom:1px solid #f5f3ef;background:var(--psa-pale);cursor:pointer;transition:background 0.15s;" onmouseover="this.style.background='#ddf0e5'" onmouseout="this.style.background='var(--psa-pale)'">
                                <div style="display:flex;gap:0.7rem;align-items:flex-start;">
                                    <div style="width:32px;height:32px;border-radius:50%;background:var(--psa-pale);border:1.5px solid var(--psa-leaf);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                        <i class="fas fa-circle-dollar-to-slot" style="font-size:0.7rem;color:var(--psa-leaf);"></i>
                                    </div>
                                    <div style="flex:1;min-width:0;">
                                        <div style="font-size:0.8rem;font-weight:500;color:var(--psa-ink);">Pago mensual depositado</div>
                                        <div style="font-size:0.72rem;color:var(--psa-muted);margin-top:1px;">Finca La Catarata · ₡3,800,000</div>
                                        <div style="font-size:0.65rem;color:var(--psa-leaf);margin-top:3px;font-weight:500;">Hace 2 horas</div>
                                    </div>
                                </div>
                            </div>
                            <!-- Notif 2 -->
                            <div style="padding:0.9rem 1.2rem;border-bottom:1px solid #f5f3ef;background:var(--psa-pale);cursor:pointer;transition:background 0.15s;" onmouseover="this.style.background='#ddf0e5'" onmouseout="this.style.background='var(--psa-pale)'">
                                <div style="display:flex;gap:0.7rem;align-items:flex-start;">
                                    <div style="width:32px;height:32px;border-radius:50%;background:var(--psa-gold-bg);border:1.5px solid var(--psa-gold);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                        <i class="fas fa-clipboard-check" style="font-size:0.7rem;color:var(--psa-gold);"></i>
                                    </div>
                                    <div style="flex:1;min-width:0;">
                                        <div style="font-size:0.8rem;font-weight:500;color:var(--psa-ink);">Visita técnica programada</div>
                                        <div style="font-size:0.72rem;color:var(--psa-muted);margin-top:1px;">Finca El Roble · Ing. Roberto Rojas · 28 mar 2026</div>
                                        <div style="font-size:0.65rem;color:var(--psa-leaf);margin-top:3px;font-weight:500;">Hace 5 horas</div>
                                    </div>
                                </div>
                            </div>
                            <!-- Notif 3 -->
                            <div style="padding:0.9rem 1.2rem;border-bottom:1px solid #f5f3ef;background:var(--psa-pale);cursor:pointer;transition:background 0.15s;" onmouseover="this.style.background='#ddf0e5'" onmouseout="this.style.background='var(--psa-pale)'">
                                <div style="display:flex;gap:0.7rem;align-items:flex-start;">
                                    <div style="width:32px;height:32px;border-radius:50%;background:var(--psa-blue-bg);border:1.5px solid var(--psa-blue);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                        <i class="fas fa-file-lines" style="font-size:0.7rem;color:var(--psa-blue);"></i>
                                    </div>
                                    <div style="flex:1;min-width:0;">
                                        <div style="font-size:0.8rem;font-weight:500;color:var(--psa-ink);">Documento requerido</div>
                                        <div style="font-size:0.72rem;color:var(--psa-muted);margin-top:1px;">Finca Las Palmas necesita plano catastrado actualizado</div>
                                        <div style="font-size:0.65rem;color:var(--psa-leaf);margin-top:3px;font-weight:500;">Ayer</div>
                                    </div>
                                </div>
                            </div>
                            <!-- Notif 4 (leída) -->
                            <div style="padding:0.9rem 1.2rem;border-bottom:1px solid #f5f3ef;cursor:pointer;transition:background 0.15s;" onmouseover="this.style.background='#fafaf8'" onmouseout="this.style.background='transparent'">
                                <div style="display:flex;gap:0.7rem;align-items:flex-start;">
                                    <div style="width:32px;height:32px;border-radius:50%;background:var(--psa-sand);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                        <i class="fas fa-circle-check" style="font-size:0.7rem;color:var(--psa-muted);"></i>
                                    </div>
                                    <div style="flex:1;min-width:0;">
                                        <div style="font-size:0.8rem;font-weight:400;color:var(--psa-muted);">Finca La Catarata aprobada</div>
                                        <div style="font-size:0.72rem;color:var(--psa-muted);margin-top:1px;">Su finca fue aceptada en el programa PSA</div>
                                        <div style="font-size:0.65rem;color:var(--psa-muted);margin-top:3px;">15 mar 2026</div>
                                    </div>
                                </div>
                            </div>
                            <!-- Notif 5 (leída) -->
                            <div style="padding:0.9rem 1.2rem;cursor:pointer;transition:background 0.15s;" onmouseover="this.style.background='#fafaf8'" onmouseout="this.style.background='transparent'">
                                <div style="display:flex;gap:0.7rem;align-items:flex-start;">
                                    <div style="width:32px;height:32px;border-radius:50%;background:var(--psa-sand);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                        <i class="fas fa-circle-dollar-to-slot" style="font-size:0.7rem;color:var(--psa-muted);"></i>
                                    </div>
                                    <div style="flex:1;min-width:0;">
                                        <div style="font-size:0.8rem;font-weight:400;color:var(--psa-muted);">Pago mensual depositado</div>
                                        <div style="font-size:0.72rem;color:var(--psa-muted);margin-top:1px;">Finca La Catarata · ₡3,800,000</div>
                                        <div style="font-size:0.65rem;color:var(--psa-muted);margin-top:3px;">10 feb 2026</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- Footer -->
                        <div style="padding:0.7rem 1.2rem;border-top:1px solid var(--psa-border);text-align:center;background:#fefefe;">
                            <a href="#" style="font-size:0.78rem;color:var(--psa-leaf);font-weight:500;text-decoration:none;" onmouseover="this.style.textDecoration='underline'" onmouseout="this.style.textDecoration='none'">Ver todas las notificaciones</a>
                        </div>
                    </div>
                </div>
                <div class="psa-topbar-icon"><i class="fas fa-circle-question"></i></div>
                <a asp-controller="Cuenta" asp-action="Perfil" style="text-decoration:none;">
                    <div class="psa-avatar" style="width:30px;height:30px;font-size:0.7rem;cursor:pointer;">CF</div>
                </a>
            </div>
        </div>
        <div class="psa-content">
            @RenderBody()
        </div>
        <footer class="psa-footer">Sistema de Gestión de Pagos por Servicios Ambientales (PSA) · FONAFIFO · SINAC · © 2026</footer>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://cdn.jsdelivr.net/npm/ag-grid-community/dist/ag-grid-community.min.js"></script>
<script>
        const API_URL_BASE = "https://spsaapi.azurewebsites.net";
    function ShowSuccess(t, x) { Swal.fire({ icon: 'success', title: t, text: x, timer: 2000 }); }
    function ShowError(t, x) { Swal.fire({ icon: 'error', title: t, text: x }); }
    function ShowConfirm(t, x, cb) { Swal.fire({ title: t, text: x, icon: 'warning', showCancelButton: true, confirmButtonColor: '#2d8653', cancelButtonColor: '#b83232', confirmButtonText: 'Confirmar', cancelButtonText: 'Cancelar' }).then(r => { if (r.isConfirmed) cb(); }); }

    // Notificaciones toggle
    function toggleNotif() {
        var panel = document.getElementById('notifPanel');
        panel.style.display = panel.style.display === 'none' ? 'block' : 'none';
    }
    document.addEventListener('click', function(e) {
        var wrapper = document.querySelector('.psa-notif-wrapper');
        var panel = document.getElementById('notifPanel');
        if (wrapper && panel && !wrapper.contains(e.target)) {
            panel.style.display = 'none';
        }
    });
</script>
    <script src="~/js/Pages/Shared/layout.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
