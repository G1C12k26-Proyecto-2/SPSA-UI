@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistema PSA</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/psatheme.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="psa-layout">

        <aside class="psa-sidebar">
            <div class="psa-sidebar-brand">
                <div class="badge-label">SINAC · FONAFIFO</div>
                <div class="brand-title">Bio<span>Pago</span> <small style="font-size:0.7rem;font-style:normal;color:rgba(255,255,255,0.4);font-family:'Epilogue',sans-serif;">Admin</small></div>
            </div>

            <div class="psa-sidebar-user">
                <div class="psa-avatar">AD</div>
                <div>
                    <div class="user-name">Admin Sistema</div>
                    <div class="user-role">Administrador</div>
                </div>
            </div>

            <nav class="psa-sidebar-nav">
                <div class="psa-nav-section">Principal</div>
                <a class="psa-nav-item @(controller == "Admin" && action == "AdminDashboard" ? "active" : "")"
                   asp-controller="Admin" asp-action="AdminDashboard">
                    <i class="fas fa-gauge-high"></i> Dashboard
                </a>

                <div class="psa-nav-section">Usuarios</div>
                <a class="psa-nav-item @(controller == "Usuarios" && action == "Index" ? "active" : "")"
                   asp-controller="Usuarios" asp-action="Index">
                    <i class="fas fa-users"></i> Usuarios
                </a>

                <div class="psa-nav-section">Sistema</div>
                <a class="psa-nav-item @(controller == "Auditoria" ? "active" : "")"
                   asp-controller="Auditoria" asp-action="Index">
                    <i class="fas fa-clock-rotate-left"></i> Auditoría
                </a>
                <a class="psa-nav-item @(controller == "Configuracion" ? "active" : "")"
                   asp-controller="Configuracion" asp-action="General">
                    <i class="fas fa-sliders"></i> Configuración
                </a>

                <div class="psa-nav-section">Reportes</div>
                <a class="psa-nav-item @(controller == "Reportes" && action == "Index" ? "active" : "")"
                   asp-controller="Reportes" asp-action="Index">
                    <i class="fas fa-chart-bar"></i> Reportes
                </a>
                <a class="psa-nav-item @(controller == "Reportes" && action == "Pagos" ? "active" : "")"
                   asp-controller="Reportes" asp-action="Pagos">
                    <i class="fas fa-circle-dollar-to-slot"></i> Reporte de Pagos
                </a>
                <a class="psa-nav-item @(controller == "Reportes" && action == "Solicitudes" ? "active" : "")"
                   asp-controller="Reportes" asp-action="Solicitudes">
                    <i class="fas fa-file-lines"></i> Reporte de Solicitudes
                </a>

                <div class="psa-nav-section">Pagos</div>
                <a class="psa-nav-item @(controller == "Pagos" && action == "Procesar" ? "active" : "")"
                   asp-controller="Pagos" asp-action="Procesar">
                    <i class="fas fa-circle-dollar-to-slot"></i> Procesar Pagos
                </a>
                <a class="psa-nav-item @(controller == "Pagos" && action == "Calcular" ? "active" : "")"
                   asp-controller="Pagos" asp-action="Calcular">
                    <i class="fas fa-calculator"></i> Calcular Pagos
                </a>
                <a class="psa-nav-item @(controller == "Pagos" && action == "Historial" ? "active" : "")"
                   asp-controller="Pagos" asp-action="Historial">
                    <i class="fas fa-receipt"></i> Historial de Pagos
                </a>
            </nav>

            <div class="psa-sidebar-footer">
                <a class="psa-logout" href="#" onclick="cerrarSesion()">
                    <i class="fas fa-right-from-bracket"></i> Cerrar sesión
                </a>
            </div>
        </aside>

        <div class="psa-main">
            <div class="psa-topbar">
                <div class="psa-breadcrumb">
                    <a asp-controller="Admin" asp-action="AdminDashboard">Sistema PSA</a>
                    <i class="fas fa-chevron-right" style="font-size:0.55rem;"></i>
                    <span class="current">@ViewData["Title"]</span>
                </div>
                <div class="psa-topbar-right">
                    <!-- NOTIFICACIONES DROPDOWN -->
                    <div class="psa-notif-wrapper" style="position:relative;">
                        <div class="psa-topbar-icon" id="btnNotif" onclick="toggleNotif()" style="cursor:pointer;">
                            <i class="fas fa-bell"></i>
                            <div class="dot"></div>
                        </div>
                        <div class="psa-notif-panel" id="notifPanel" style="display:none;position:absolute;top:calc(100% + 8px);right:0;width:360px;background:#fff;border-radius:var(--psa-r);border:1px solid var(--psa-border);box-shadow:0 12px 40px rgba(13,43,26,0.12);z-index:999;overflow:hidden;">
                            <div style="padding:0.9rem 1.2rem;border-bottom:1px solid var(--psa-border);display:flex;align-items:center;justify-content:space-between;background:#fefefe;">
                                <div style="font-family:'Fraunces',serif;font-size:0.95rem;font-weight:500;color:var(--psa-forest);display:flex;align-items:center;gap:0.4rem;">
                                    <i class="fas fa-bell" style="font-size:0.82rem;color:var(--psa-leaf);"></i> Notificaciones
                                </div>
                                <span style="font-size:0.6rem;font-weight:600;background:var(--psa-pale);color:var(--psa-leaf);padding:0.15rem 0.5rem;border-radius:99px;">2 nuevas</span>
                            </div>
                            <div style="max-height:340px;overflow-y:auto;">
                                <div style="padding:0.9rem 1.2rem;border-bottom:1px solid #f5f3ef;background:var(--psa-pale);cursor:pointer;transition:background 0.15s;" onmouseover="this.style.background='#ddf0e5'" onmouseout="this.style.background='var(--psa-pale)'">
                                    <div style="display:flex;gap:0.7rem;align-items:flex-start;">
                                        <div style="width:32px;height:32px;border-radius:50%;background:var(--psa-pale);border:1.5px solid var(--psa-leaf);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                            <i class="fas fa-user-plus" style="font-size:0.7rem;color:var(--psa-leaf);"></i>
                                        </div>
                                        <div style="flex:1;min-width:0;">
                                            <div style="font-size:0.8rem;font-weight:500;color:var(--psa-ink);">Nuevo usuario registrado</div>
                                            <div style="font-size:0.72rem;color:var(--psa-muted);margin-top:1px;">María Rodríguez · Rol: Propietario</div>
                                            <div style="font-size:0.65rem;color:var(--psa-leaf);margin-top:3px;font-weight:500;">Hace 1 hora</div>
                                        </div>
                                    </div>
                                </div>
                                <div style="padding:0.9rem 1.2rem;border-bottom:1px solid #f5f3ef;background:var(--psa-pale);cursor:pointer;transition:background 0.15s;" onmouseover="this.style.background='#ddf0e5'" onmouseout="this.style.background='var(--psa-pale)'">
                                    <div style="display:flex;gap:0.7rem;align-items:flex-start;">
                                        <div style="width:32px;height:32px;border-radius:50%;background:var(--psa-gold-bg);border:1.5px solid var(--psa-gold);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                            <i class="fas fa-circle-dollar-to-slot" style="font-size:0.7rem;color:var(--psa-gold);"></i>
                                        </div>
                                        <div style="flex:1;min-width:0;">
                                            <div style="font-size:0.8rem;font-weight:500;color:var(--psa-ink);">Lote de pagos procesado</div>
                                            <div style="font-size:0.72rem;color:var(--psa-muted);margin-top:1px;">12 pagos ejecutados · ₡42,600,000</div>
                                            <div style="font-size:0.65rem;color:var(--psa-leaf);margin-top:3px;font-weight:500;">Hace 3 horas</div>
                                        </div>
                                    </div>
                                </div>
                                <div style="padding:0.9rem 1.2rem;border-bottom:1px solid #f5f3ef;cursor:pointer;transition:background 0.15s;" onmouseover="this.style.background='#fafaf8'" onmouseout="this.style.background='transparent'">
                                    <div style="display:flex;gap:0.7rem;align-items:flex-start;">
                                        <div style="width:32px;height:32px;border-radius:50%;background:var(--psa-sand);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                            <i class="fas fa-tree" style="font-size:0.7rem;color:var(--psa-muted);"></i>
                                        </div>
                                        <div style="flex:1;min-width:0;">
                                            <div style="font-size:0.8rem;font-weight:400;color:var(--psa-muted);">Nueva solicitud de finca</div>
                                            <div style="font-size:0.72rem;color:var(--psa-muted);margin-top:1px;">Finca El Roble · Carlos Fonseca</div>
                                            <div style="font-size:0.65rem;color:var(--psa-muted);margin-top:3px;">Ayer</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div style="padding:0.7rem 1.2rem;border-top:1px solid var(--psa-border);text-align:center;background:#fefefe;">
                                <a href="#" style="font-size:0.78rem;color:var(--psa-leaf);font-weight:500;text-decoration:none;" onmouseover="this.style.textDecoration='underline'" onmouseout="this.style.textDecoration='none'">Ver todas las notificaciones</a>
                            </div>
                        </div>
                    </div>
                    <div class="psa-topbar-icon Juan4"><i class="fas fa-circle-question"></i></div>
                    <a asp-controller="Admin" asp-action="AdminDashboard" style="text-decoration:none;">
                        <div class="psa-avatar" style="width:30px;height:30px;font-size:0.7rem;cursor:pointer;">AD</div>
                    </a>
                </div>
            </div>

            <div class="psa-content">
                @RenderBody()
            </div>

            <footer class="psa-footer">
                Sistema de Gestión de Pagos por Servicios Ambientales (PSA) · FONAFIFO · SINAC · © 2026
            </footer>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/ag-grid-community/dist/ag-grid-community.min.js"></script>
    <script>
        function ShowSuccess(t, x) { Swal.fire({ icon: 'success', title: t, text: x, timer: 2000 }); }
        function ShowError(t, x)   { Swal.fire({ icon: 'error',   title: t, text: x }); }
        function ShowConfirm(t, x, cb) {
            Swal.fire({ title: t, text: x, icon: 'warning', showCancelButton: true,
                confirmButtonColor: '#2d8653', cancelButtonColor: '#b83232',
                confirmButtonText: 'Confirmar', cancelButtonText: 'Cancelar'
            }).then(r => { if (r.isConfirmed) cb(); });
        }

        function toggleNotif() {
            var panel = document.getElementById('notifPanel');
            panel.style.display = panel.style.display === 'none' ? 'block' : 'none';
        }
        document.addEventListener('click', function(e) {
            var wrapper = document.querySelector('.psa-notif-wrapper');
            var panel = document.getElementById('notifPanel');
            if (wrapper && panel && !wrapper.contains(e.target)) {
                panel.style.display = 'none';
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
    <script src="~/js/Pages/Shared/layout.js" asp-append-version="true"></script>
</body>
</html>