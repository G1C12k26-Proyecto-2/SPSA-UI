@{
    ViewData["Title"] = "Historial de Pagos";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="psa-page-header">
    <div>
        <span class="subtitle">Pagos</span>
        <h1>Historial de Pagos</h1>
        <p>Registro completo de todos los pagos ejecutados</p>
    </div>
</div>

<div class="psa-card">
    <div class="psa-filters">
        <input type="text" class="form-control form-control-sm" placeholder="Buscar finca o propietario..." style="max-width:240px;" />
        <select class="form-select form-select-sm" style="max-width:160px;">
            <option>Todos los estados</option>
            <option>Ejecutado</option>
            <option>Pendiente</option>
        </select>
        <div class="spacer"></div>
        <button class="btn btn-outline-psa btn-sm"><i class="fas fa-download"></i> Exportar</button>
    </div>
    <table class="table table-hover mb-0" style="font-size:0.82rem;">
        <thead style="background:#fafaf8;">
            <tr>
                <th style="padding:0.8rem 1.3rem;font-size:0.68rem;letter-spacing:1.5px;text-transform:uppercase;color:var(--psa-muted);font-weight:600;border-bottom:1px solid var(--psa-border);">Finca</th>
                <th style="padding:0.8rem 1.3rem;font-size:0.68rem;letter-spacing:1.5px;text-transform:uppercase;color:var(--psa-muted);font-weight:600;border-bottom:1px solid var(--psa-border);">Propietario</th>
                <th style="padding:0.8rem 1.3rem;font-size:0.68rem;letter-spacing:1.5px;text-transform:uppercase;color:var(--psa-muted);font-weight:600;border-bottom:1px solid var(--psa-border);">Período</th>
                <th style="padding:0.8rem 1.3rem;font-size:0.68rem;letter-spacing:1.5px;text-transform:uppercase;color:var(--psa-muted);font-weight:600;border-bottom:1px solid var(--psa-border);">Monto</th>
                <th style="padding:0.8rem 1.3rem;font-size:0.68rem;letter-spacing:1.5px;text-transform:uppercase;color:var(--psa-muted);font-weight:600;border-bottom:1px solid var(--psa-border);">Fecha</th>
                <th style="padding:0.8rem 1.3rem;font-size:0.68rem;letter-spacing:1.5px;text-transform:uppercase;color:var(--psa-muted);font-weight:600;border-bottom:1px solid var(--psa-border);">Estado</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td style="padding:0.9rem 1.3rem;">Finca La Catarata</td>
                <td style="padding:0.9rem 1.3rem;">Carlos Fonseca</td>
                <td style="padding:0.9rem 1.3rem;">Mar 2026</td>
                <td style="padding:0.9rem 1.3rem;"><strong>₡3,800,000</strong></td>
                <td style="padding:0.9rem 1.3rem;">10/03/2026</td>
                <td style="padding:0.9rem 1.3rem;"><span class="psa-badge psa-badge-green">Ejecutado</span></td>
            </tr>
            <tr>
                <td style="padding:0.9rem 1.3rem;">Finca La Catarata</td>
                <td style="padding:0.9rem 1.3rem;">Carlos Fonseca</td>
                <td style="padding:0.9rem 1.3rem;">Feb 2026</td>
                <td style="padding:0.9rem 1.3rem;"><strong>₡3,800,000</strong></td>
                <td style="padding:0.9rem 1.3rem;">10/02/2026</td>
                <td style="padding:0.9rem 1.3rem;"><span class="psa-badge psa-badge-green">Ejecutado</span></td>
            </tr>
            <tr>
                <td style="padding:0.9rem 1.3rem;">Finca Las Palmas</td>
                <td style="padding:0.9rem 1.3rem;">Ana Solano</td>
                <td style="padding:0.9rem 1.3rem;">Ene–Mar 2026</td>
                <td style="padding:0.9rem 1.3rem;"><strong>₡3,100,000</strong></td>
                <td style="padding:0.9rem 1.3rem;">—</td>
                <td style="padding:0.9rem 1.3rem;"><span class="psa-badge psa-badge-gold">Pendiente</span></td>
            </tr>
        </tbody>
    </table>
</div>