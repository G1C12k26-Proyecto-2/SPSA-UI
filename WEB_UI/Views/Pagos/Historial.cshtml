@{
    ViewData["Title"] = "Historial de Pagos";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="psa-page-header">
    <div>
        <span class="subtitle">Pagos</span>
        <h1>Historial de Pagos</h1>
        <p>Registro completo de todos los pagos ejecutados</p>
    </div>
</div>

<div class="psa-card">
    <div class="psa-filters">
        <input type="text" class="form-control form-control-sm" placeholder="Buscar finca o propietario..." style="max-width:240px;" id="pagosSearch" />
        <select class="form-select form-select-sm" style="max-width:160px;" id="pagosEstado">
            <option value="">Todos los estados</option>
            <option value="Ejecutado">Ejecutado</option>
            <option value="Pendiente">Pendiente</option>
        </select>
        <div class="spacer"></div>
        <button class="btn btn-outline-psa btn-sm"><i class="fas fa-download"></i> Exportar</button>
    </div>
    <div id="gridPagosHistorial" style="height:400px;width:100%;" class="ag-theme-alpine"></div>
</div>

@section Scripts {
    <script src="~/js/Pages/Pagos/HistorialGrid.js" asp-append-version="true"></script>
}