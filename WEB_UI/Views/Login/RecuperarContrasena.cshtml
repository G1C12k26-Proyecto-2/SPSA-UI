@{
    ViewData["Title"] = "Recuperar Contraseña";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Recuperar Contraseña - Sistema PSA</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,300;0,500;0,700;1,300&family=Epilogue:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Epilogue', sans-serif;
            background: #f4f1eb;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .wrapper {
            display: flex;
            width: 100%;
            max-width: 900px;
            min-height: 520px;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 8px 40px rgba(13,43,26,0.12);
        }

        .left {
            flex: 1;
            background: linear-gradient(180deg, #052417 0%, #0d2b1a 100%);
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 3rem;
            color: white;
        }

        .badge-label {
            display: inline-block;
            font-size: 0.58rem;
            font-weight: 600;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: #4caf7d;
            background: rgba(77,175,125,0.15);
            padding: 0.2rem 0.5rem;
            border-radius: 3px;
            margin-bottom: 1.2rem;
        }

        .brand-title {
            font-family: 'Fraunces', serif;
            font-size: 2rem;
            font-weight: 500;
            color: #fff;
            margin-bottom: 0.8rem;
        }

            .brand-title span {
                color: #4caf7d;
                font-style: italic;
            }

        .brand-desc {
            font-size: 0.85rem;
            color: rgba(255,255,255,0.5);
            line-height: 1.6;
        }

        .right {
            flex: 1;
            background: #fff;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 3rem;
        }

            .right h2 {
                font-family: 'Fraunces', serif;
                font-size: 1.6rem;
                font-weight: 500;
                color: #0d2b1a;
                margin-bottom: 0.3rem;
            }

            .right p {
                font-size: 0.82rem;
                color: #5c6b60;
                margin-bottom: 2rem;
                line-height: 1.6;
            }

        .form-label-psa {
            font-size: 0.7rem;
            font-weight: 600;
            letter-spacing: 0.8px;
            text-transform: uppercase;
            color: #5c6b60;
            display: block;
            margin-bottom: 0.4rem;
        }

        .form-control {
            border: 1px solid #d6ddd8;
            border-radius: 8px;
            padding: 0.75rem 1rem;
            font-size: 0.88rem;
            font-family: 'Epilogue', sans-serif;
            width: 100%;
            margin-bottom: 1rem;
        }

            .form-control:focus {
                outline: none;
                border-color: #2d8653;
                box-shadow: 0 0 0 3px #e8f5ee;
            }

        .btn-psa {
            background: #2d8653;
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: 0.85rem;
            font-size: 0.95rem;
            font-weight: 500;
            font-family: 'Epilogue', sans-serif;
            width: 100%;
            cursor: pointer;
            transition: background 0.2s;
            margin-bottom: 0.8rem;
        }

            .btn-psa:hover {
                background: #1e5c38;
            }

        .btn-outline {
            background: #fff;
            color: #2d8653;
            border: 1.5px solid #d6ddd8;
            border-radius: 8px;
            padding: 0.85rem;
            font-size: 0.95rem;
            font-weight: 500;
            font-family: 'Epilogue', sans-serif;
            width: 100%;
            cursor: pointer;
            transition: border-color 0.2s;
            text-align: center;
            text-decoration: none;
            display: block;
        }

            .btn-outline:hover {
                border-color: #2d8653;
                color: #2d8653;
            }

        .error-msg {
            background: #fdeaea;
            color: #b83232;
            border-radius: 8px;
            padding: 0.75rem 1rem;
            font-size: 0.82rem;
            margin-bottom: 1rem;
            display: none;
        }

        .success-msg {
            background: #e8f5ee;
            color: #2d8653;
            border-radius: 8px;
            padding: 0.75rem 1rem;
            font-size: 0.82rem;
            margin-bottom: 1rem;
            display: none;
        }

        .step {
            display: none;
        }

            .step.active {
                display: block;
            }

        .otp-inputs {
            display: flex;
            gap: 0.6rem;
            margin-bottom: 1rem;
        }

            .otp-inputs input {
                flex: 1;
                text-align: center;
                font-size: 1.4rem;
                font-weight: 600;
                border: 1px solid #d6ddd8;
                border-radius: 8px;
                padding: 0.75rem 0;
                font-family: 'Epilogue', sans-serif;
            }

                .otp-inputs input:focus {
                    outline: none;
                    border-color: #2d8653;
                    box-shadow: 0 0 0 3px #e8f5ee;
                }

        .timer {
            text-align: center;
            font-size: 0.78rem;
            color: #5c6b60;
            margin-bottom: 1rem;
        }

            .timer span {
                color: #2d8653;
                font-weight: 600;
            }

        .row-fields {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0 1rem;
        }

        .fa-spin {
            animation: psa-spin 0.7s linear infinite;
        }

        @@keyframes psa-spin {
            to {
                transform: rotate(360deg);
            }
        }
    </style>
</head>
<body>
    <div class="wrapper">
        <div class="left">
            <div class="badge-label">SINAC · FONAFIFO</div>
            <div class="brand-title">Bio<span>Pago</span></div>
            <p class="brand-desc">
                Recuperá el acceso<br />
                a tu cuenta PSA.<br /><br />
                Te enviaremos un código<br />
                de verificación a tu<br />
                correo electrónico.
            </p>
        </div>

        <div class="right">

            <!-- PASO 1 — Ingresar correo -->
            <div class="step active" id="step1">
                <h2>Recuperar Contraseña</h2>
                <p>Ingresá tu correo registrado y te enviaremos un link de verificación.</p>

                <div class="error-msg" id="errorStep1">
                    <i class="fas fa-circle-exclamation"></i>
                    <span id="errorTextStep1"></span>
                </div>

                <label class="form-label-psa">Correo / Usuario</label>
                <input type="text" class="form-control" id="txtCorreo" placeholder="correo@psa.cr" />

                <button class="btn-psa" onclick="enviarOTP()">
                    <i class="fas fa-paper-plane"></i> Enviar Link
                </button>
                <a href="/Cuenta/Login" class="btn-outline">Volver al Login</a>
            </div>

            <!-- PASO 2 — Ingresar OTP -->
            <div class="step" id="step2">
                <h2>Verificar Código</h2>
                <p>Ingresá el código de 6 dígitos que enviamos a tu correo. Válido por <strong>2 minutos</strong>.</p>

                <div class="error-msg" id="errorStep2">
                    <i class="fas fa-circle-exclamation"></i>
                    <span id="errorTextStep2"></span>
                </div>

                <div class="otp-inputs">
                    <input type="text" maxlength="1" id="otp1" oninput="moverFoco(this, 'otp2')" />
                    <input type="text" maxlength="1" id="otp2" oninput="moverFoco(this, 'otp3')" />
                    <input type="text" maxlength="1" id="otp3" oninput="moverFoco(this, 'otp4')" />
                    <input type="text" maxlength="1" id="otp4" oninput="moverFoco(this, 'otp5')" />
                    <input type="text" maxlength="1" id="otp5" oninput="moverFoco(this, 'otp6')" />
                    <input type="text" maxlength="1" id="otp6" oninput="moverFoco(this, null)" />
                </div>

                <div class="timer">
                    Código expira en <span id="countdown">2:00</span>
                </div>

                <button class="btn-psa" onclick="verificarOTP()">
                    <i class="fas fa-check"></i> Verificar Código
                </button>
                <button class="btn-outline" onclick="irStep(1)" style="border:none;color:#5c6b60;font-size:0.82rem;background:none;width:100%;cursor:pointer;margin-top:0.5rem;">
                    ¿No recibiste el código? Reenviar
                </button>
            </div>

            <!-- PASO 3 — Nueva contraseña -->
            <div class="step" id="step3">
                <h2>Nueva Contraseña</h2>
                <p>Ingresá tu nueva contraseña. Debe tener al menos 6 caracteres.</p>

                <div class="error-msg" id="errorStep3">
                    <i class="fas fa-circle-exclamation"></i>
                    <span id="errorTextStep3"></span>
                </div>

                <div class="success-msg" id="successStep3">
                    <i class="fas fa-circle-check"></i>
                    Contraseña actualizada. Redirigiendo al login...
                </div>

                <div class="row-fields">
                    <div>
                        <label class="form-label-psa">Nueva Contraseña</label>
                        <input type="password" class="form-control" id="txtNueva" placeholder="Mínimo 6 caracteres" />
                    </div>
                    <div>
                        <label class="form-label-psa">Confirmar Contraseña</label>
                        <input type="password" class="form-control" id="txtConfirmar" placeholder="Repetí la contraseña" />
                    </div>
                </div>

                <button class="btn-psa" onclick="cambiarContrasena()">
                    <i class="fas fa-lock"></i> Guardar Nueva Contraseña
                </button>
            </div>

        </div>
    </div>

    <script>
        let timerInterval = null;

        function irStep(n) {
            document.querySelectorAll('.step').forEach(s => s.classList.remove('active'));
            document.getElementById('step' + n).classList.add('active');
            if (n === 2) iniciarTimer();
            else clearInterval(timerInterval);
        }

        function enviarOTP() {
            const correo = document.getElementById('txtCorreo').value.trim();
            const error  = document.getElementById('errorStep1');
            const errorText = document.getElementById('errorTextStep1');
            error.style.display = 'none';

            if (!correo) {
                errorText.textContent = 'Por favor ingresá tu correo.';
                error.style.display = 'block';
                return;
            }

            // Cuando el backend tenga el endpoint, aquí va el fetch
            // Por ahora avanza directo al paso 2
            irStep(2);
        }

        function moverFoco(actual, siguienteId) {
            if (actual.value.length === 1 && siguienteId) {
                document.getElementById(siguienteId).focus();
            }
        }

        function verificarOTP() {
            const otp = ['otp1','otp2','otp3','otp4','otp5','otp6']
                .map(id => document.getElementById(id).value).join('');
            const error = document.getElementById('errorStep2');
            const errorText = document.getElementById('errorTextStep2');
            error.style.display = 'none';

            if (otp.length < 6) {
                errorText.textContent = 'Ingresá los 6 dígitos del código.';
                error.style.display = 'block';
                return;
            }

            // Cuando el backend tenga el endpoint, aquí va la verificación
            // Por ahora avanza directo al paso 3
            irStep(3);
        }

        function cambiarContrasena() {
            const nueva     = document.getElementById('txtNueva').value;
            const confirmar = document.getElementById('txtConfirmar').value;
            const error     = document.getElementById('errorStep3');
            const errorText = document.getElementById('errorTextStep3');
            const success   = document.getElementById('successStep3');
            error.style.display = 'none';

            if (!nueva || !confirmar) {
                errorText.textContent = 'Por favor completá ambos campos.';
                error.style.display = 'block';
                return;
            }

            if (nueva !== confirmar) {
                errorText.textContent = 'Las contraseñas no coinciden.';
                error.style.display = 'block';
                return;
            }

            if (nueva.length < 6) {
                errorText.textContent = 'La contraseña debe tener al menos 6 caracteres.';
                error.style.display = 'block';
                return;
            }

            // Cuando el backend tenga el endpoint, aquí va el fetch
            // Por ahora simula éxito
            success.style.display = 'block';
            setTimeout(() => {
                window.location.href = '/Cuenta/Login';
            }, 2000);
        }

        function iniciarTimer() {
            let segundos = 120;
            const countdown = document.getElementById('countdown');
            clearInterval(timerInterval);
            timerInterval = setInterval(() => {
                segundos--;
                const m = Math.floor(segundos / 60);
                const s = segundos % 60;
                countdown.textContent = `${m}:${s.toString().padStart(2, '0')}`;
                if (segundos <= 0) {
                    clearInterval(timerInterval);
                    countdown.textContent = 'Expirado';
                    countdown.style.color = '#b83232';
                }
            }, 1000);
        }
    </script>
</body>
</html>