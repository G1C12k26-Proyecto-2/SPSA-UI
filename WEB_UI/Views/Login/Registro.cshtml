@{
    ViewData["Title"] = "Registro";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Registro - Sistema PSA</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,300;0,500;0,700;1,300&family=Epilogue:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Epilogue', sans-serif;
            background: #f4f1eb;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem 1rem;
        }

        .registro-wrapper {
            display: flex;
            width: 100%;
            max-width: 900px;
            min-height: 620px;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 8px 40px rgba(13,43,26,0.12);
        }

        .registro-left {
            flex: 1;
            background: linear-gradient(180deg, #052417 0%, #0d2b1a 100%);
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 3rem;
            color: white;
        }

        .badge-label {
            display: inline-block;
            font-size: 0.58rem;
            font-weight: 600;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: #4caf7d;
            background: rgba(77,175,125,0.15);
            padding: 0.2rem 0.5rem;
            border-radius: 3px;
            margin-bottom: 1.2rem;
        }

        .brand-title {
            font-family: 'Fraunces', serif;
            font-size: 2rem;
            font-weight: 500;
            color: #fff;
            margin-bottom: 0.8rem;
        }

            .brand-title span {
                color: #4caf7d;
                font-style: italic;
            }

        .brand-desc {
            font-size: 0.85rem;
            color: rgba(255,255,255,0.5);
            line-height: 1.6;
        }

        .registro-right {
            flex: 1.2;
            background: #fff;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 3rem;
            overflow-y: auto;
        }

            .registro-right h2 {
                font-family: 'Fraunces', serif;
                font-size: 1.6rem;
                font-weight: 500;
                color: #0d2b1a;
                margin-bottom: 0.3rem;
            }

            .registro-right p {
                font-size: 0.82rem;
                color: #5c6b60;
                margin-bottom: 1.5rem;
            }

        .form-label-psa {
            font-size: 0.7rem;
            font-weight: 600;
            letter-spacing: 0.8px;
            text-transform: uppercase;
            color: #5c6b60;
            display: block;
            margin-bottom: 0.4rem;
        }

        .form-control {
            border: 1px solid #d6ddd8;
            border-radius: 8px;
            padding: 0.75rem 1rem;
            font-size: 0.88rem;
            font-family: 'Epilogue', sans-serif;
            width: 100%;
            margin-bottom: 1rem;
        }

            .form-control:focus {
                outline: none;
                border-color: #2d8653;
                box-shadow: 0 0 0 3px #e8f5ee;
            }

        .btn-psa {
            background: #2d8653;
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: 0.85rem;
            font-size: 0.95rem;
            font-weight: 500;
            font-family: 'Epilogue', sans-serif;
            width: 100%;
            cursor: pointer;
            transition: background 0.2s;
        }

            .btn-psa:hover {
                background: #1e5c38;
            }

            .btn-psa:disabled {
                background: #8a9a8e;
                cursor: not-allowed;
            }

        .error-msg {
            background: #fdeaea;
            color: #b83232;
            border-radius: 8px;
            padding: 0.75rem 1rem;
            font-size: 0.82rem;
            margin-bottom: 1rem;
            display: none;
        }

        .success-msg {
            background: #e8f5ee;
            color: #2d8653;
            border-radius: 8px;
            padding: 0.75rem 1rem;
            font-size: 0.82rem;
            margin-bottom: 1rem;
            display: none;
        }

        .login-link {
            text-align: center;
            margin-top: 1rem;
            font-size: 0.82rem;
            color: #5c6b60;
        }

            .login-link a {
                color: #2d8653;
                text-decoration: none;
            }

                .login-link a:hover {
                    text-decoration: underline;
                }

        .row-fields {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0 1rem;
        }

        .fa-spin {
            animation: psa-spin 0.7s linear infinite;
        }

        @@keyframes psa-spin {
            to {
                transform: rotate(360deg);
            }
        }
    </style>
</head>
<body>
    <div class="registro-wrapper">
        <div class="registro-left">
            <div class="badge-label">SINAC · FONAFIFO</div>
            <div class="brand-title">Bio<span>Pago</span></div>
            <p class="brand-desc">
                Registrate como<br />
                Dueño de Finca para<br />
                ingresar al programa PSA.<br /><br />
                Técnicos e Ingenieros<br />
                son registrados por el<br />
                Administrador del sistema.
            </p>
        </div>

        <div class="registro-right">
            <h2>Crear Cuenta</h2>
            <p>Completá tus datos para registrarte como Dueño de Finca</p>

            <div class="error-msg" id="errorMsg">
                <i class="fas fa-circle-exclamation"></i>
                <span id="errorText">Ocurrió un error.</span>
            </div>

            <div class="success-msg" id="successMsg">
                <i class="fas fa-circle-check"></i>
                <span id="successText">Cuenta creada exitosamente. Redirigiendo al login...</span>
            </div>

            <label class="form-label-psa">Nombre Completo</label>
            <input type="text" class="form-control" id="txtNombre"
                   placeholder="Nombre y apellidos" />

            <label class="form-label-psa">Correo / Usuario</label>
            <input type="text" class="form-control" id="txtUsuario"
                   placeholder="correo@ejemplo.com" />

            <div class="row-fields">
                <div>
                    <label class="form-label-psa">Contraseña</label>
                    <input type="password" class="form-control" id="txtPassword"
                           placeholder="Mínimo 6 caracteres" />
                </div>
                <div>
                    <label class="form-label-psa">Confirmar Contraseña</label>
                    <input type="password" class="form-control" id="txtConfirmar"
                           placeholder="Repetí la contraseña" />
                </div>
            </div>

            <button class="btn-psa" id="btnRegistro" onclick="doRegistro()">
                Crear Cuenta
            </button>

            <div class="login-link">
                ¿Ya tenés cuenta? <a href="/Cuenta/Login">Iniciá sesión</a>
            </div>
        </div>
    </div>

    <script>
        const API_URL = "https://spsaapi.azurewebsites.net";

        async function doRegistro() {
            const nombre    = document.getElementById('txtNombre').value.trim();
            const usuario   = document.getElementById('txtUsuario').value.trim();
            const password  = document.getElementById('txtPassword').value;
            const confirmar = document.getElementById('txtConfirmar').value;
            const errorMsg  = document.getElementById('errorMsg');
            const errorText = document.getElementById('errorText');
            const successMsg = document.getElementById('successMsg');
            const btn       = document.getElementById('btnRegistro');

            errorMsg.style.display   = 'none';
            successMsg.style.display = 'none';

            if (!nombre || !usuario || !password || !confirmar) {
                errorText.textContent = 'Por favor completá todos los campos.';
                errorMsg.style.display = 'block';
                return;
            }

            if (password !== confirmar) {
                errorText.textContent = 'Las contraseñas no coinciden.';
                errorMsg.style.display = 'block';
                return;
            }

            if (password.length < 6) {
                errorText.textContent = 'La contraseña debe tener al menos 6 caracteres.';
                errorMsg.style.display = 'block';
                return;
            }

            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Creando cuenta...';

            try {
                const response = await fetch(`${API_URL}/api/Auth/CreateUser`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        userName: usuario,
                        password: password,
                        fullName: nombre
                    })
                });

                const data = await response.json();

                if (data.result === 'ok') {
                    successMsg.style.display = 'block';
                    setTimeout(() => {
                        window.location.href = '/Cuenta/Login';
                    }, 2000);
                } else {
                    errorText.textContent = data.message || 'No se pudo crear la cuenta.';
                    errorMsg.style.display = 'block';
                }
            } catch (e) {
                errorText.textContent = 'No se pudo conectar con el servidor.';
                errorMsg.style.display = 'block';
            } finally {
                btn.disabled = false;
                btn.innerHTML = 'Crear Cuenta';
            }
        }
    </script>
</body>
</html>