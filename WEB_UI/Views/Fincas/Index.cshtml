@{
    ViewData["Title"] = "Mis Fincas";
    ViewData["Breadcrumb"] = "Mis Fincas";
}

<div class="psa-page-header">
    <div>
        <span class="subtitle">Mis Propiedades</span>
        <h1>Mis Fincas</h1>
        <p>Listado de todas las propiedades registradas</p>
    </div>
    <a class="btn btn-psa btn-sm" asp-controller="Fincas" asp-action="Crear"><i class="fas fa-plus"></i> Registrar Nueva Finca</a>
</div>

<div class="psa-stats">
    <div class="psa-stat-card">
        <div class="psa-stat-header">
            <div class="psa-stat-label">Total Fincas</div>
            <div class="psa-stat-icon green"><i class="fas fa-tree"></i></div>
        </div>
        <div class="psa-stat-value">4</div>
        <div class="psa-stat-sub">Registradas</div>
    </div>
    <div class="psa-stat-card">
        <div class="psa-stat-header">
            <div class="psa-stat-label">Activas en PSA</div>
            <div class="psa-stat-icon green"><i class="fas fa-circle-check"></i></div>
        </div>
        <div class="psa-stat-value">2</div>
        <div class="psa-stat-sub">Recibiendo pagos</div>
    </div>
    <div class="psa-stat-card">
        <div class="psa-stat-header">
            <div class="psa-stat-label">En Proceso</div>
            <div class="psa-stat-icon gold"><i class="fas fa-hourglass-half"></i></div>
        </div>
        <div class="psa-stat-value">1</div>
        <div class="psa-stat-sub">Pendiente evaluación</div>
    </div>
    <div class="psa-stat-card">
        <div class="psa-stat-header">
            <div class="psa-stat-label">Total Hectáreas</div>
            <div class="psa-stat-icon blue"><i class="fas fa-map"></i></div>
        </div>
        <div class="psa-stat-value">67</div>
        <div class="psa-stat-sub">ha registradas</div>
    </div>
</div>

<div class="psa-card">
    <div class="psa-filters">
        <input type="text" id="txtSearch" class="form-control form-control-sm" placeholder="Buscar finca..." style="max-width:220px;" />
        <select class="form-select form-select-sm" style="max-width:160px;">
            <option value="">Todos los estados</option>
            <option>PSA Activo</option>
            <option>En Evaluación</option>
            <option>En Revisión</option>
            <option>Rechazada</option>
        </select>
        <select class="form-select form-select-sm" style="max-width:160px;">
            <option value="">Todas las provincias</option>
            <option>Alajuela</option>
            <option>Heredia</option>
            <option>Cartago</option>
            <option>Guanacaste</option>
            <option>Puntarenas</option>
        </select>
    </div>
    <div id="gridFincas" style="height:400px;width:100%;" class="ag-theme-alpine"></div>
</div>

@section Scripts {
    <script src="~/js/Pages/Fincas/fincalist.js" asp-append-version="true"></script>
}
