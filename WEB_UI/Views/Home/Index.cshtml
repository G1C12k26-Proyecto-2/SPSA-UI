@{
    ViewData["Title"] = "Gestión de Pagos por Servicios Ambientales";
}

<!-- ═══════ HEADER ═══════ -->
<header class="bp-header" id="bpHeader">
    <div class="bp-container">
        <div class="bp-header-inner">
            <a class="bp-logo" href="#">
                <i class="fas fa-leaf"></i> Bio<span>Pagos</span>
            </a>
            <button class="bp-menu-toggle" id="menuToggle"><i class="fas fa-bars"></i></button>
            <ul class="bp-nav" id="bpNav">
                <li><a href="#features">Beneficios</a></li>
                <li><a href="#process">Proceso</a></li>
                <li><a href="#impact">Impacto</a></li>
                <li><a href="#testimonials">Testimonios</a></li>
                <li><a href="#cta" class="bp-nav-cta">Comenzar Ahora</a></li>
            </ul>
        </div>
    </div>
</header>

<!-- ═══════ HERO ═══════ -->
<section class="bp-hero">
    <i class="fas fa-leaf bp-hero-leaf"></i>
    <i class="fas fa-tree bp-hero-leaf"></i>
    <i class="fas fa-seedling bp-hero-leaf"></i>
    <div class="bp-container">
        <div class="bp-hero-content">
            <div class="bp-hero-badge"><i class="fas fa-shield-halved"></i> SINAC · FONAFIFO · Costa Rica</div>
            <h1>Protegé el bosque,<br>recibí tu <em>pago</em></h1>
            <p class="bp-hero-text">
                BioPagos digitaliza la gestión de Pagos por Servicios Ambientales. Registrá tus fincas,
                dá seguimiento a solicitudes y recibí depósitos automáticos — todo desde una sola plataforma.
            </p>
            <div class="bp-hero-actions">
                <a href="#cta" class="bp-btn-primary"><i class="fas fa-rocket"></i> Registrar Mi Finca</a>
                <a href="#process" class="bp-btn-ghost"><i class="fas fa-play-circle"></i> Cómo Funciona</a>
            </div>
            <div class="bp-hero-stats">
                <div>
                    <div class="bp-hero-stat-value">12,400+</div>
                    <div class="bp-hero-stat-label">Hectáreas protegidas</div>
                </div>
                <div>
                    <div class="bp-hero-stat-value">₡4.2B</div>
                    <div class="bp-hero-stat-label">Pagos procesados</div>
                </div>
                <div>
                    <div class="bp-hero-stat-value">860</div>
                    <div class="bp-hero-stat-label">Fincas activas</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ═══════ SECCIÓN 1: BENEFICIOS ═══════ -->
<section class="bp-section bp-features" id="features">
    <div class="bp-container">
        <div class="text-center">
            <div class="bp-section-label">Beneficios</div>
            <h2 class="bp-section-title">Todo lo que necesitás, en un solo lugar</h2>
            <p class="bp-section-subtitle center">Simplificamos cada paso del proceso PSA para que te enfoqués en lo que importa: conservar.</p>
        </div>
        <div class="bp-features-grid">
            <div class="bp-feature-card">
                <div class="bp-feature-icon green"><i class="fas fa-tree"></i></div>
                <h3>Registro Digital de Fincas</h3>
                <p>Registrá tus propiedades con ubicación GPS, tipo de vegetación, recursos hídricos y documentos legales. Sin papeleos.</p>
            </div>
            <div class="bp-feature-card">
                <div class="bp-feature-icon gold"><i class="fas fa-calculator"></i></div>
                <h3>Cálculo Automático de Pagos</h3>
                <p>El sistema calcula tu pago mensual según hectáreas, tipo de bosque, recursos hídricos y pendiente del terreno.</p>
            </div>
            <div class="bp-feature-card">
                <div class="bp-feature-icon blue"><i class="fas fa-chart-line"></i></div>
                <h3>Seguimiento en Tiempo Real</h3>
                <p>Consultá el estado de tus solicitudes, evaluaciones técnicas, historial de pagos y próximos depósitos al instante.</p>
            </div>
            <div class="bp-feature-card">
                <div class="bp-feature-icon green"><i class="fas fa-building-columns"></i></div>
                <h3>Depósitos Automáticos</h3>
                <p>Configurá tu cuenta bancaria una sola vez. Los pagos se depositan el día 15 de cada mes de forma automática y segura.</p>
            </div>
            <div class="bp-feature-card">
                <div class="bp-feature-icon gold"><i class="fas fa-shield-halved"></i></div>
                <h3>Datos Protegidos</h3>
                <p>Tu información personal y bancaria se almacena con cifrado AES-256. Seguridad de nivel bancario para tu tranquilidad.</p>
            </div>
            <div class="bp-feature-card">
                <div class="bp-feature-icon blue"><i class="fas fa-file-lines"></i></div>
                <h3>Documentación Centralizada</h3>
                <p>Planos catastrados, escrituras, fotografías y planes de manejo forestal organizados y accesibles desde cualquier dispositivo.</p>
            </div>
        </div>
    </div>
</section>

<!-- ═══════ SECCIÓN 2: PROCESO ═══════ -->
<section class="bp-section bp-process" id="process">
    <div class="bp-container">
        <div class="text-center">
            <div class="bp-section-label">Proceso</div>
            <h2 class="bp-section-title">Cuatro pasos para recibir tu pago</h2>
            <p class="bp-section-subtitle center">Desde el registro hasta el depósito, el proceso es simple y transparente.</p>
        </div>
        <div class="bp-process-steps">
            <div class="bp-step">
                <div class="bp-step-number">1</div>
                <h4>Registrá tu Finca</h4>
                <p>Completá los datos de ubicación, vegetación, recursos hídricos y subí los documentos legales requeridos.</p>
            </div>
            <div class="bp-step">
                <div class="bp-step-number">2</div>
                <h4>Evaluación Técnica</h4>
                <p>Un ingeniero forestal realiza la visita de campo y verifica las condiciones ambientales de tu propiedad.</p>
            </div>
            <div class="bp-step">
                <div class="bp-step-number">3</div>
                <h4>Aprobación PSA</h4>
                <p>FONAFIFO revisa el informe técnico y aprueba tu finca para el programa de Pagos por Servicios Ambientales.</p>
            </div>
            <div class="bp-step">
                <div class="bp-step-number">4</div>
                <h4>Recibí tu Pago</h4>
                <p>Configurá tu cuenta bancaria y comenzá a recibir depósitos mensuales automáticos por conservar tu bosque.</p>
            </div>
        </div>
    </div>
</section>

<!-- ═══════ SECCIÓN 3: IMPACTO ═══════ -->
<section class="bp-section bp-impact" id="impact">
    <div class="bp-container">
        <div class="text-center" style="position:relative;z-index:2;">
            <div class="bp-section-label">Impacto</div>
            <h2 class="bp-section-title">Conservación que se mide en resultados</h2>
            <p class="bp-section-subtitle center">Cada hectárea protegida genera impacto real para Costa Rica y el planeta.</p>
        </div>
        <div class="bp-impact-grid">
            <div class="bp-impact-card">
                <i class="fas fa-tree"></i>
                <div class="bp-impact-value">12,400</div>
                <div class="bp-impact-label">Hectáreas de bosque protegidas</div>
            </div>
            <div class="bp-impact-card">
                <i class="fas fa-droplet"></i>
                <div class="bp-impact-value">340</div>
                <div class="bp-impact-label">Nacientes de agua resguardadas</div>
            </div>
            <div class="bp-impact-card">
                <i class="fas fa-users"></i>
                <div class="bp-impact-value">860</div>
                <div class="bp-impact-label">Familias beneficiadas</div>
            </div>
            <div class="bp-impact-card">
                <i class="fas fa-cloud"></i>
                <div class="bp-impact-value">28K</div>
                <div class="bp-impact-label">Toneladas de CO₂ capturadas/año</div>
            </div>
        </div>
    </div>
</section>

