@{
    ViewData["Title"] = "Programar Visita - Ingeniero Forestal";
    Layout = "~/Views/Shared/_LayoutIngForestal.cshtml";
}

@section Styles {
    <!-- Ya no necesitas estas fuentes porque psatheme.css ya las define -->
    <!-- <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet"> -->
    <!-- <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet"> -->
    <!-- <link rel="stylesheet" href="~/css/ingforestal/dashboard.css" asp-append-version="true" /> -->
    <!-- <link rel="stylesheet" href="~/css/ingforestal/programar.css" asp-append-version="true" /> -->

    <style>
        /* Estilos específicos para el stepper y formulario */
        .pr-stepper {
            display: flex;
            gap: 0.5rem;
            margin-bottom: 2rem;
            background: #fff;
            padding: 1rem;
            border-radius: var(--psa-r);
            border: 1px solid var(--psa-border);
        }
        .pr-step {
            flex: 1;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.75rem;
            border-radius: var(--psa-r);
            transition: background 0.2s;
        }
        .pr-step.activo {
            background: var(--psa-pale);
        }
        .pr-step-num {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            background: var(--psa-sand);
            color: var(--psa-muted);
        }
        .pr-step.activo .pr-step-num {
            background: var(--psa-leaf);
            color: #fff;
        }
        .pr-step-titulo {
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--psa-ink);
        }
        .pr-step-sub {
            font-size: 0.7rem;
            color: var(--psa-muted);
        }
        
        /* Panel y secciones */
        .pr-seccion {
            display: none;
        }
        .pr-seccion.activa {
            display: block;
        }
        
        /* Formulario grid */
        .pr-form-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1rem;
        }
        .pr-field {
            grid-column: span 1;
        }
        .pr-field.span-2 {
            grid-column: span 2;
        }
        .pr-field label {
            font-size: 0.7rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--psa-muted);
            margin-bottom: 0.25rem;
            display: block;
        }
        .pr-field .req {
            color: var(--psa-red);
        }
        .pr-field .hint {
            font-size: 0.65rem;
            font-weight: normal;
            text-transform: none;
            color: var(--psa-muted);
        }
        .pr-input-icon-wrap {
            position: relative;
        }
        .pr-input-icon {
            position: absolute;
            left: 10px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--psa-muted);
            font-size: 0.75rem;
        }
        .pr-input-icon-wrap input,
        .pr-input-icon-wrap select {
            padding-left: 30px;
        }
        .pr-field-error {
            font-size: 0.7rem;
            color: var(--psa-red);
            display: none;
            margin-top: 0.25rem;
        }
        .pr-field-error.visible {
            display: block;
        }
        
        /* Búsqueda de solicitudes */
        .pr-buscar-solicitud {
            position: relative;
            margin-bottom: 1rem;
        }
        .pr-search-ic {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--psa-muted);
            font-size: 0.8rem;
        }
        .pr-buscar-solicitud input {
            width: 100%;
            padding: 0.5rem 0.5rem 0.5rem 2rem;
            border: 1px solid var(--psa-border);
            border-radius: 6px;
            font-size: 0.85rem;
        }
        .pr-buscar-solicitud input:focus {
            border-color: var(--psa-leaf);
            outline: none;
            box-shadow: 0 0 0 3px rgba(45,134,83,0.1);
        }
        
        /* Lista de solicitudes */
        .pr-solicitudes-lista {
            max-height: 400px;
            overflow-y: auto;
            border: 1px solid var(--psa-border);
            border-radius: var(--psa-r);
        }
        .pr-solicitud-item {
            padding: 0.75rem;
            border-bottom: 1px solid var(--psa-border);
            cursor: pointer;
            transition: background 0.2s;
        }
        .pr-solicitud-item:last-child {
            border-bottom: none;
        }
        .pr-solicitud-item:hover {
            background: var(--psa-pale);
        }
        .pr-solicitud-item.seleccionada {
            background: var(--psa-pale);
            border-left: 3px solid var(--psa-leaf);
        }
        .pr-solicitud-nombre {
            font-weight: 600;
            color: var(--psa-forest);
            margin-bottom: 0.25rem;
        }
        .pr-solicitud-detalle {
            font-size: 0.75rem;
            color: var(--psa-muted);
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
        }
        
        /* Divisor */
        .pr-divider {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin: 1.5rem 0 1rem;
            font-size: 0.7rem;
            font-weight: 600;
            text-transform: uppercase;
            color: var(--psa-muted);
        }
        .pr-divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--psa-border);
        }
        
        /* Confirmación */
        .pr-confirmacion {
            text-align: center;
            padding: 1rem;
        }
        .pr-confirmacion-icon {
            font-size: 2.5rem;
            margin-bottom: 1rem;
        }
        .pr-confirmacion h3 {
            font-family: 'Fraunces', serif;
            font-size: 1.2rem;
            color: var(--psa-forest);
            margin-bottom: 0.5rem;
        }
        .pr-confirmacion p {
            font-size: 0.85rem;
            color: var(--psa-muted);
            margin-bottom: 1.5rem;
        }
        .pr-confirmacion-detalle {
            background: var(--psa-pale);
            border-radius: var(--psa-r);
            padding: 1rem;
            text-align: left;
            font-size: 0.85rem;
        }
        
        /* Resumen */
        .pr-resumen-body {
            padding: 1rem;
        }
        .pr-resumen-item {
            display: flex;
            justify-content: space-between;
            padding: 0.5rem 0;
            border-bottom: 1px solid var(--psa-border);
        }
        .pr-resumen-item:last-child {
            border-bottom: none;
        }
        .pr-resumen-label {
            font-size: 0.75rem;
            color: var(--psa-muted);
        }
        .pr-resumen-valor {
            font-size: 0.75rem;
            font-weight: 500;
            color: var(--psa-ink);
        }
        .pr-resumen-valor.vacio {
            color: var(--psa-muted);
            font-style: italic;
        }
        .pr-resumen-alerta {
            display: flex;
            gap: 0.75rem;
            padding: 1rem;
            background: var(--psa-pale);
            border-radius: var(--psa-r);
            font-size: 0.75rem;
            color: var(--psa-muted);
        }
        
        /* Form actions */
        .pr-form-actions {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 1.5rem;
            gap: 1rem;
            flex-wrap: wrap;
        }
        .pr-form-actions-right {
            display: flex;
            gap: 0.75rem;
        }
    </style>
}

<div class="IngForestal-dashboard">

    <!-- ===== BREADCRUMB ===== -->


    <!-- ===== PAGE HEADER ===== -->
    <div class="psa-page-header">
        <div>
            <span class="subtitle">Nueva Visita Técnica</span>
            <h1>
                <i class="fas fa-calendar-plus" style="color: var(--psa-leaf); font-size: 1.4rem;"></i>
                Programar Visita Técnica
            </h1>
            <p>Complete los 3 pasos para registrar una nueva visita de evaluación.</p>
        </div>
    </div>

    <!-- ===== STEPPER ===== -->
    <div class="pr-stepper" role="list" aria-label="Pasos del formulario">
        <div class="pr-step activo" role="listitem" aria-current="step">
            <div class="pr-step-num">1</div>
            <div class="pr-step-label">
                <div class="pr-step-titulo">Solicitud</div>
                <div class="pr-step-sub">Seleccionar finca</div>
            </div>
        </div>
        <div class="pr-step" role="listitem">
            <div class="pr-step-num">2</div>
            <div class="pr-step-label">
                <div class="pr-step-titulo">Detalles</div>
                <div class="pr-step-sub">Fecha y logística</div>
            </div>
        </div>
        <div class="pr-step" role="listitem">
            <div class="pr-step-num">3</div>
            <div class="pr-step-label">
                <div class="pr-step-titulo">Confirmar</div>
                <div class="pr-step-sub">Revisar y guardar</div>
            </div>
        </div>
    </div>

    <!-- ===== LAYOUT PRINCIPAL ===== -->
    <div style="display: grid; grid-template-columns: 1fr 320px; gap: 1.5rem; align-items: start;">

        <!-- COLUMNA IZQUIERDA: FORMULARIO -->
        <div style="display: flex; flex-direction: column; gap: 1.5rem;">

            <!-- ══════ PASO 1: SELECCIÓN DE SOLICITUD ══════ -->
            <div class="pr-seccion activa" id="pr-seccion-1">
                <div class="psa-card">
                    <div class="psa-card-header">
                        <div class="psa-card-title">
                            <i class="fas fa-file-alt"></i> Seleccionar Solicitud Pendiente
                        </div>
                        <span style="font-size: 0.7rem; color: var(--psa-muted);">Elija la finca que desea evaluar</span>
                    </div>
                    <div class="psa-card-body">
                        <!-- Búsqueda -->
                        <div class="pr-buscar-solicitud">
                            <i class="fas fa-search pr-search-ic"></i>
                            <input type="text" id="pr-buscar-sol" class="form-control form-control-sm"
                                   placeholder="Buscar por finca, propietario o ubicación..."
                                   style="padding-left: 30px;"
                                   aria-label="Buscar solicitud">
                        </div>

                        <!-- Error selección -->
                        <div class="pr-field-error" id="pr-sol-err" role="alert" style="margin-bottom: 12px; display: none;">
                            <i class="fas fa-triangle-exclamation"></i>
                            Debe seleccionar una solicitud para continuar.
                        </div>

                        <!-- Lista de solicitudes -->
<div class="pr-solicitudes-lista" id="pr-lista-solicitudes"
     role="radiogroup" aria-label="Solicitudes pendientes">
    
    <!-- Finca Los Robles -->
    <div class="pr-solicitud-item" data-id="1" 
