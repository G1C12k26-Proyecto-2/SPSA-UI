@{
    ViewData["Title"] = "Detalle de Evaluación - Ingeniero Forestal";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // En producción estos valores vienen del modelo
    var evalId          = "3";
    var estadoActual    = "proceso";
    var nombreFinca     = "Parcela Monteverdi";
    var propietario     = "Diego Campos";
    var ubicacion       = "Pérez Zeledón, San José";
    var ingenieroAsig   = "Ing. Carlos Pérez";

    // Datos de la finca
    var hectareas       = "31.00";
    var vegetacion      = "Bosque Primario";
    var pendiente       = "Inclinada";
    var recursos        = "Río y naciente";
    var usoSuelo        = new[] { "Conservación", "Protección de nacientes" };

    // Datos de la visita
    var fechaSolicitud  = "07/03/2026";
    var fechaVisita     = "28/03/2026";
    var horaVisita      = "07:00 AM";

    // Observaciones
    var observaciones   = "Se observó una cobertura forestal primaria en buen estado. La quebrada principal presenta caudal constante y dos nacientes identificadas al norte del predio. El terreno presenta una pendiente inclinada homogénea. No se detectaron actividades agropecuarias dentro del área delimitada.";

    // Cálculo (en producción viene calculado del backend)
    var precioBase      = 50000m;
    var has             = 31.00m;
    var pctVeg          = 30;   // bosque primario
    var pctPend         = 10;   // inclinada
    var pctRec          = 15;   // río y naciente
    var tope            = 40;
    var pctTotalRaw     = pctVeg + pctPend + pctRec;
    var pctAplicado     = pctTotalRaw > tope ? tope : pctTotalRaw;
    var montoBase       = precioBase * has;
    var montoAjuste     = montoBase * (pctAplicado / 100m);
    var montoTotal      = montoBase + montoAjuste;

    // Etiqueta estado
    string etiqEstado = estadoActual switch {
        "proceso"   => "En Proceso",
        "pendiente" => "Pendiente",
        "aprobada"  => "Aprobada",
        "rechazada" => "Rechazada",
        _           => estadoActual
    };
}

@section Styles {
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/ingforestal/dashboard.css"               asp-append-version="true" />
    <link rel="stylesheet" href="~/css/ingforestal/evaluaciones-detalle.css"    asp-append-version="true" />
}

<!-- Campo oculto para que el JS conozca el estado actual -->
<input type="hidden" id="ed-estado-actual" value="@estadoActual">

<div class="tecnico-dashboard">

    <!-- ===== BREADCRUMB ===== -->
    <nav class="ed-breadcrumb" aria-label="Ruta de navegación">
        <a href="@Url.Action("TecnicoDashboard", "IngForestal")">
            <i class="fa-solid fa-house-chimney"></i> Dashboard
        </a>
        <span class="ed-breadcrumb-sep"><i class="fa-solid fa-chevron-right"></i></span>
        <a href="@Url.Action("EvaluacionesPendientes","IngForestal")">Evaluaciones</a>
        <span class="ed-breadcrumb-sep"><i class="fa-solid fa-chevron-right"></i></span>
        <span>@nombreFinca</span>
    </nav>

    <!-- ===== PAGE HEADER ===== -->
    <div class="ed-page-header">
        <div>
            <h1>@nombreFinca</h1>
            <div class="ed-meta">
                <span class="chip chip-@estadoActual ed-chip-estado">● @etiqEstado</span>
                <span class="ed-meta-item">
                    <i class="fa-solid fa-user"></i> @propietario
                </span>
                <span class="ed-meta-item">
                    <i class="fa-solid fa-location-dot"></i> @ubicacion
                </span>
                <span class="ed-meta-item">
                    <i class="fa-solid fa-user-tie"></i> @ingenieroAsig
                </span>
            </div>
        </div>
        <div class="ed-header-actions">
            <button class="btn btn-outline"
                    onclick="location.href='@Url.Action("EvaluacionesPendientes","IngForestal")'">
                <i class="fa-solid fa-arrow-left"></i> Volver
            </button>
            <button class="btn btn-outline" id="ed-btn-editar"
                    onclick="edEditar()" style="display:none;">
                <i class="fa-solid fa-pen-to-square"></i> Editar
            </button>
            <button class="btn btn-outline" onclick="edAbrirModal()">
                <i class="fa-solid fa-arrow-right-arrow-left"></i> Cambiar Estado
            </button>
            <button class="btn btn-primary" id="ed-btn-realizar"
                    onclick="edRealizar()" style="display:none;">
                <i class="fa-solid fa-clipboard-check"></i> Realizar Visita
            </button>
        </div>
    </div>

    <!-- ===== LAYOUT ===== -->
    <div class="ed-body">

        <!-- ══════ COLUMNA PRINCIPAL ══════ -->
        <div>

            <!-- ── 1. DATOS DE LA FINCA ── -->
            <div class="ed-panel">
                <div class="ed-panel-header">
                    <h2><i class="fa-solid fa-tree"></i> Datos de la Finca</h2>
                </div>
                <div class="ed-panel-body">
                    <div class="ed-data-grid">
                        <div class="ed-data-item">
                            <span class="ed-data-label">Propietario</span>
                            <span class="ed-data-valor destacado">@propietario</span>
                        </div>
                        <div class="ed-data-item">
                            <span class="ed-data-label">Ubicación</span>
                            <span class="ed-data-valor">@ubicacion</span>
                        </div>
                        <div class="ed-data-item">
                            <span class="ed-data-label">Hectáreas verificadas</span>
                            <span class="ed-data-valor destacado">@hectareas ha</span>
                        </div>
                        <div class="ed-data-item">
                            <span class="ed-data-label">Tipo de vegetación</span>
                            <span class="ed-data-valor">@vegetacion</span>
                        </div>
                        <div class="ed-data-item">
                            <span class="ed-data-label">Pendiente del terreno</span>
                            <span class="ed-data-valor">@pendiente</span>
                        </div>
                        <div class="ed-data-item">
                            <span class="ed-data-label">Recursos hídricos</span>
                            <span class="ed-data-valor">@recursos</span>
                        </div>
                        <div class="ed-data-item">
                            <span class="ed-data-label">Fecha de solicitud</span>
                            <span class="ed-data-valor">@fechaSolicitud</span>
                        </div>
                        <div class="ed-data-item">
                            <span class="ed-data-label">Ingeniero asignado</span>
                            <span class="ed-data-valor">@ingenieroAsig</span>
                        </div>
                    </div>

                    @if (usoSuelo.Length > 0) {
                        <div style="margin-top:20px;">
                            <span class="ed-data-label" style="display:block;margin-bottom:10px;">Uso de suelo</span>
                            <div class="ed-tags-wrap">
                                @foreach (var uso in usoSuelo) {
                                    <span class="ed-tag">
                                        <i class="fa-solid fa-check" style="font-size:.65rem;"></i> @uso
                                    </span>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- ── 2. DATOS DE LA VISITA ── -->
            <div class="ed-panel">
                <div class="ed-panel-header">
                    <h2><i class="fa-solid fa-calendar-check"></i> Datos de la Visita</h2>
                </div>
                <div class="ed-panel-body">
                    <div class="ed-data-grid" style="margin-bottom:20px;">
                        <div class="ed-data-item">
                            <span class="ed-data-label">Fecha programada</span>
                            <span class="ed-data-valor destacado">@fechaVisita</span>
                        </div>
                        <div class="ed-data-item">
                            <span class="ed-data-label">Hora de inicio</span>
                            <span class="ed-data-valor">@horaVisita</span>
                        </div>
                    </div>

                    <!-- Observaciones -->
                    <span class="ed-data-label" style="display:block;margin-bottom:10px;">
                        <i class="fa-solid fa-pen-nib" style="color:var(--verde-claro);"></i>
                        Observaciones técnicas del ingeniero
                    </span>
                    <div class="ed-obs-box">@observaciones</div>
                </div>
            </div>

            <!-- ── 3. CÁLCULO DE PAGO ESTIMADO ── -->
            <div class="ed-panel">
                <div class="ed-panel-header">
                    <h2><i class="fa-solid fa-coins"></i> Cálculo de Pago Mensual Estimado</h2>
                </div>
                <div class="ed-panel-body" style="padding:0;">
                    <div class="ed-calculo-wrap">
                        <div class="ed-calculo-header">
                            <div class="ed-calculo-header-left">
                                <p>Pago mensual estimado</p>
                                <div class="ed-calculo-monto">
                                    ₡@montoTotal.ToString("N0", new System.Globalization.CultureInfo("es-CR"))
                                </div>
                                <div class="ed-calculo-sub">
                                    Tope de ajustes: @tope% &nbsp;·&nbsp; Ajuste aplicado: @pctAplicado%
                                    @if (pctTotalRaw > tope) {
                                        <span>(limitado desde @pctTotalRaw%)</span>
                                    }
                                </div>
                            </div>
                            <div class="ed-calculo-icon">💰</div>
                        </div>
                        <div class="ed-calculo-filas">
                            <div class="ed-calculo-fila">
                                <span class="ed-calculo-label">Precio base por hectárea</span>
                                <span class="ed-calculo-val">₡@precioBase.ToString("N0", new System.Globalization.CultureInfo("es-CR"))</span>
                            </div>
                            <div class="ed-calculo-fila">
                                <span class="ed-calculo-label">Hectáreas verificadas</span>
                                <span class="ed-calculo-val">@hectareas ha</span>
                            </div>
                            <div class="ed-calculo-fila">
                                <span class="ed-calculo-label">Monto base (@hectareas ha × ₡@precioBase.ToString("N0", new System.Globalization.CultureInfo("es-CR")))</span>
                                <span class="ed-calculo-val">₡@montoBase.ToString("N0", new System.Globalization.CultureInfo("es-CR"))</span>
                            </div>
                            <div class="ed-calculo-fila">
                                <span class="ed-calculo-label">Ajuste vegetación (@vegetacion)</span>
                                <span class="ed-calculo-val positivo">+@pctVeg%</span>
                            </div>
                            <div class="ed-calculo-fila">
                                <span class="ed-calculo-label">Ajuste pendiente (@pendiente)</span>
                                <span class="ed-calculo-val positivo">+@pctPend%</span>
                            </div>
                            <div class="ed-calculo-fila">
                                <span class="ed-calculo-label">Ajuste recursos hídricos (@recursos)</span>
                                <span class="ed-calculo-val positivo">+@pctRec%</span>
                            </div>
                            <div class="ed-calculo-fila">
                                <span class="ed-calculo-label">Total ajuste aplicado</span>
                                <span class="ed-calculo-val positivo">
                                    +@pctAplicado% = ₡@montoAjuste.ToString("N0", new System.Globalization.CultureInfo("es-CR"))
                                </span>
                            </div>
                            <div class="ed-calculo-fila" style="border-top:2px solid var(--borde);padding-top:12px;margin-top:4px;">
                                <span class="ed-calculo-label" style="color:var(--verde-bosque);font-weight:700;font-size:.92rem;">
                                    Total mensual estimado
                                </span>
                                <span class="ed-calculo-val total">
                                    ₡@montoTotal.ToString("N0", new System.Globalization.CultureInfo("es-CR"))
                                </span>
                            </div>
                        </div>
                        <p class="ed-calculo-nota">
                            Estimación referencial basada en los parámetros vigentes al momento de la evaluación.
                            El monto final es calculado y ejecutado por el sistema de pagos al aprobar la solicitud.
                        </p>
                    </div>
                </div>
            </div>

            <!-- ── 4. HISTORIAL DE CAMBIOS ── -->
            <div class="ed-panel">
                <div class="ed-panel-header">
                    <h2><i class="fa-solid fa-clock-rotate-left"></i> Historial de Actividad</h2>
                </div>
                <div class="ed-historial">
                    <div class="ed-historial-item">
                        <div class="ed-historial-dot creado"></div>
                        <div class="ed-historial-info">
                            <div class="ed-historial-accion">Solicitud recibida</div>
                            <div class="ed-historial-sub">Estado inicial — Pendiente de evaluación</div>
                        </div>
                        <div class="ed-historial-fecha">07/03/2026 08:14</div>
                    </div>
                    <div class="ed-historial-item">
                        <div class="ed-historial-dot proceso"></div>
                        <div class="ed-historial-info">
                            <div class="ed-historial-accion">Evaluación iniciada</div>
                            <div class="ed-historial-sub">Asignada a @ingenieroAsig — Estado: En Proceso</div>
                        </div>
                        <div class="ed-historial-fecha">15/03/2026 09:30</div>
                    </div>
                    <div class="ed-historial-item">
                        <div class="ed-historial-dot editado"></div>
                        <div class="ed-historial-info">
                            <div class="ed-historial-accion">Datos técnicos actualizados</div>
                            <div class="ed-historial-sub">Modificación de hectáreas y recursos hídricos</div>
                        </div>
                        <div class="ed-historial-fecha">20/03/2026 14:05</div>
                    </div>
                </div>
            </div>

        </div><!-- /columna principal -->

        <!-- ══════ ASIDE ══════ -->
        <div class="ed-aside">

            <!-- Tarjeta de estado -->
            <div class="ed-estado-card">
                <div class="ed-estado-header">
                    <div class="ed-estado-header-label">Estado actual</div>
                    <div class="ed-estado-chip-grande" id="ed-estado-grande">
                        <i class="fa-solid fa-spinner"></i> @etiqEstado
                    </div>
                </div>
                <div class="ed-estado-body">
                    <div class="ed-estado-fila">
                        <span class="ed-estado-fila-label">Solicitud</span>
                        <span class="ed-estado-fila-val">@fechaSolicitud</span>
                    </div>
                    <div class="ed-estado-fila">
                        <span class="ed-estado-fila-label">Visita programada</span>
                        <span class="ed-estado-fila-val">@fechaVisita</span>
                    </div>
                    <div class="ed-estado-fila">
                        <span class="ed-estado-fila-label">Hora</span>
                        <span class="ed-estado-fila-val">@horaVisita</span>
                    </div>
                    <div class="ed-estado-fila">
                        <span class="ed-estado-fila-label">Hectáreas</span>
                        <span class="ed-estado-fila-val">@hectareas ha</span>
                    </div>
                    <div class="ed-estado-fila">
                        <span class="ed-estado-fila-label">Pago estimado</span>
                        <span class="ed-estado-fila-val" style="color:var(--verde-bosque);">
                            ₡@montoTotal.ToString("N0", new System.Globalization.CultureInfo("es-CR"))
                        </span>
                    </div>
                </div>
            </div>

            <!-- Acciones -->
            <div class="ed-acciones-aside">
                <h3><i class="fa-solid fa-bolt"></i> Acciones</h3>

                <button class="btn btn-primary" id="ed-btn-realizar"
                        onclick="edRealizar()"
                        style="display:none;justify-content:center;">
                    <i class="fa-solid fa-clipboard-check"></i> Realizar Visita
                </button>
                <button class="btn btn-outline" id="ed-btn-editar"
                        onclick="edEditar()"
                        style="display:none;justify-content:center;">
                    <i class="fa-solid fa-pen-to-square"></i> Editar Evaluación
                </button>
                <button class="btn btn-outline" onclick="edAbrirModal()"
                        style="justify-content:center;">
                    <i class="fa-solid fa-arrow-right-arrow-left"></i> Cambiar Estado
                </button>
                <button class="btn btn-outline"
                        onclick="location.href='@Url.Action("EvaluacionesPendientes","IngForestal")'"
                        style="justify-content:center;">
                    <i class="fa-solid fa-list"></i> Ver Evaluaciones
                </button>
                <button class="btn btn-outline"
                        onclick="location.href='@Url.Action("TecnicoDashboard", "IngForestal")'"
                        style="justify-content:center;">
                    <i class="fa-solid fa-house-chimney"></i> Dashboard
                </button>
            </div>

        </div><!-- /aside -->

    </div><!-- /ed-body -->

</div><!-- /tecnico-dashboard -->

<!-- ===== MODAL: CAMBIAR ESTADO ===== -->
<div class="ed-modal-overlay" id="ed-modal-overlay"
     role="dialog" aria-modal="true" aria-labelledby="ed-modal-titulo">
    <div class="ed-modal">
        <div class="ed-modal-head">
            <h3 id="ed-modal-titulo">
                <i class="fa-solid fa-arrow-right-arrow-left" style="color:var(--verde-claro);"></i>
                Cambiar Estado de Evaluación
            </h3>
            <button class="ed-modal-close" onclick="edCerrarModal()" aria-label="Cerrar">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>
        <div class="ed-modal-body">
            <form id="ed-form-estado" novalidate>

                <div class="ed-field">
                    <label for="ed-nuevo-estado">
                        Nuevo estado <span class="req">*</span>
                    </label>
                    <select id="ed-nuevo-estado" onchange="edOnEstadoCambio()"
                            aria-describedby="ed-nuevo-estado-err">
                        <option value="">Seleccione...</option>
                        <option value="proceso">En Proceso</option>
                        <option value="aprobada">Aprobada</option>
                        <option value="rechazada">Rechazada</option>
                    </select>
                    <span class="ed-field-error" id="ed-nuevo-estado-err" role="alert">
                        <i class="fa-solid fa-triangle-exclamation"></i>
                        Debe seleccionar un nuevo estado.
                    </span>
                </div>

                <div class="ed-field" id="ed-wrap-motivo" style="display:none;">
                    <label for="ed-motivo">Observación (opcional)</label>
                    <textarea id="ed-motivo" rows="3"
                              placeholder="Ingrese una observación o motivo..."
                              aria-describedby="ed-motivo-err"></textarea>
                    <span class="ed-field-error" id="ed-motivo-err" role="alert">
                        <i class="fa-solid fa-triangle-exclamation"></i>
                        El motivo de rechazo debe tener al menos 10 caracteres.
                    </span>
                </div>

            </form>
        </div>
        <div class="ed-modal-footer">
            <button class="btn btn-outline" onclick="edCerrarModal()">
                <i class="fa-solid fa-xmark"></i> Cancelar
            </button>
            <button class="btn btn-primary" onclick="edGuardarEstado()">
                <i class="fa-solid fa-check"></i> Guardar Cambio
            </button>
        </div>
    </div>
</div>

<!-- ===== TOAST ===== -->
<div class="td-toast" id="ed-toast" role="alert" aria-live="polite">
    <i class="fa-solid fa-circle-check"></i>
    <span id="ed-toast-msg">Acción realizada.</span>
</div>

@section Scripts {
    <script src="~/js/pages/ingforestal/evaluaciones-detalle.js" asp-append-version="true"></script>
}
