@{
    ViewData["Title"] = "Editar Evaluación - Ingeniero Forestal";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // En producción estos valores vienen del modelo
    var evalId         = "3";
    var nombreFinca    = "Parcela Monteverdi";
    var propietario    = "Diego Campos";
    var ubicacion      = "Pérez Zeledón, San José";
    var estadoActual   = "proceso";

    // Valores actuales guardados (prellenan el formulario)
    var cHectareas     = "31.00";
    var cVegetacion    = "bosque-primario";
    var cPendiente     = "inclinada";
    var cRecursos      = "rio-naciente";
    var cFechaVisita   = "2026-03-28";
    var cHoraVisita    = "07:00";
    var cObservaciones = "Se observó una cobertura forestal primaria en buen estado. La quebrada principal presenta caudal constante y dos nacientes identificadas al norte del predio.";

    // Uso de suelo guardado (array para marcar checkboxes)
    var usoSueloActual = new[] { "conservacion", "proteccion-nacientes" };

    // Helpers de etiquetas
    var etiqVeg = new Dictionary<string,string> {
        {"bosque-primario","Bosque Primario"},{"bosque-secundario","Bosque Secundario"},
        {"plantacion-forestal","Plantación Forestal"},{"pasto","Pasto"}
    };
    var etiqPen = new Dictionary<string,string> {
        {"plana","Plana"},{"inclinada","Inclinada"},{"muy-inclinada","Muy inclinada"}
    };
    var etiqRec = new Dictionary<string,string> {
        {"ninguno","Ninguno"},{"quebrada","Quebrada"},{"rio","Río"},
        {"naciente","Naciente"},{"rio-naciente","Río y naciente"}
    };

    // Opciones de selects
    var optsVeg = new[] {
        ("bosque-primario","Bosque Primario (+30%)"),
        ("bosque-secundario","Bosque Secundario (+20%)"),
        ("plantacion-forestal","Plantación Forestal (+10%)"),
        ("pasto","Pasto o escasa vegetación (0%)")
    };
    var optsPen = new[] {
        ("plana","Plana (0%)"),
        ("inclinada","Inclinada (+10%)"),
        ("muy-inclinada","Muy inclinada (+20%)")
    };
    var optsRec = new[] {
        ("ninguno","Ninguno (0%)"),
        ("quebrada","Quebrada (0%)"),
        ("rio","Río (+10%)"),
        ("naciente","Naciente (+5%)"),
        ("rio-naciente","Río y naciente (+15%)")
    };

    var usoSueloOpts = new[] {
        ("conservacion","Conservación"),
        ("reforestacion","Reforestación"),
        ("agropecuario","Agropecuario"),
        ("agroforestal","Agroforestal"),
        ("proteccion-nacientes","Protección nacientes"),
        ("sin-uso","Sin uso definido")
    };
}

@section Styles {
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/ingforestal/dashboard.css"              asp-append-version="true" />
    <link rel="stylesheet" href="~/css/ingforestal/evaluaciones-editar.css"    asp-append-version="true" />
}

<div class="tecnico-dashboard">

    <!-- ===== BREADCRUMB ===== -->
    <nav class="ee-breadcrumb" aria-label="Ruta de navegación">
        <a href="@Url.Action("Index","IngForestal")">
            <i class="fa-solid fa-house-chimney"></i> Dashboard
        </a>
        <span class="ee-breadcrumb-sep"><i class="fa-solid fa-chevron-right"></i></span>
        <a href="@Url.Action("EvaluacionesPendientes","IngForestal")">Evaluaciones</a>
        <span class="ee-breadcrumb-sep"><i class="fa-solid fa-chevron-right"></i></span>
        <a href="@Url.Action("EvaluacionesDetalle","IngForestal", new { id = evalId })">@nombreFinca</a>
        <span class="ee-breadcrumb-sep"><i class="fa-solid fa-chevron-right"></i></span>
        <span>Editar</span>
    </nav>

    <!-- ===== PAGE HEADER ===== -->
    <div class="ee-page-header">
        <div>
            <h1>
                <i class="fa-solid fa-pen-to-square" style="color:var(--verde-claro);font-size:1.4rem;"></i>
                Editar Evaluación
            </h1>
            <div class="ee-meta">
                <span class="chip chip-@estadoActual">
                    ● @(estadoActual == "proceso" ? "En Proceso" : estadoActual == "pendiente" ? "Pendiente" : estadoActual == "aprobada" ? "Aprobada" : "Rechazada")
                </span>
                <span class="ee-meta-item">
                    <i class="fa-solid fa-tree"></i> @nombreFinca
                </span>
                <span class="ee-meta-item">
                    <i class="fa-solid fa-user"></i> @propietario
                </span>
                <span class="ee-meta-item">
                    <i class="fa-solid fa-location-dot"></i> @ubicacion
                </span>
            </div>
        </div>
        <div class="ee-header-actions">
            <button class="btn btn-outline" onclick="eeConfirmarSalir()">
                <i class="fa-solid fa-arrow-left"></i> Volver
            </button>
        </div>
    </div>

    <!-- ===== ALERTA CAMBIOS PENDIENTES ===== -->
    <div class="ee-alerta-cambios" id="ee-alerta-cambios" role="status" aria-live="polite">
        <i class="fa-solid fa-circle-exclamation"></i>
        Hay cambios sin guardar. Recuerde guardar antes de salir.
    </div>

    <!-- ===== LAYOUT ===== -->
    <div class="ee-body">

        <!-- ══════ COLUMNA PRINCIPAL ══════ -->
        <div>

            <!-- ── 1. COMPARADOR ORIGINAL vs NUEVO ── -->
            <div class="ee-panel">
                <div class="ee-panel-header">
                    <h2><i class="fa-solid fa-code-compare"></i> Comparación de Cambios</h2>
                    <span class="ee-badge-cambios" id="ee-badge-cambios">
                        <i class="fa-solid fa-pen"></i> 0 cambios
                    </span>
                </div>
                <div class="ee-panel-body">
                    <div class="ee-comparar-grid">
                        <div class="ee-comparar-col">
                            <span class="ee-comparar-titulo original">
                                <i class="fa-solid fa-clock-rotate-left"></i> Valor original
                            </span>
                            <div id="ee-comp-original"><!-- JS --></div>
                        </div>
                        <div class="ee-comparar-col">
                            <span class="ee-comparar-titulo nuevo">
                                <i class="fa-solid fa-pen"></i> Valor nuevo
                            </span>
                            <div id="ee-comp-nuevo"><!-- JS --></div>
                        </div>
                    </div>
                    <p style="font-size:.76rem;color:var(--gris-medio);margin:0;font-style:italic;">
                        <i class="fa-solid fa-circle-info"></i>
                        Los valores resaltados en amarillo indican cambios respecto al registro guardado.
                    </p>
                </div>
            </div>

            <!-- ── 2. DATOS TÉCNICOS ── -->
            <div class="ee-panel">
                <div class="ee-panel-header">
                    <h2><i class="fa-solid fa-magnifying-glass-chart"></i> Datos Técnicos</h2>
                </div>
                <div class="ee-panel-body">

                    <!-- Referencia de la finca (solo lectura) -->
                    <div class="ee-form-grid" style="margin-bottom:20px;">
                        <div class="ee-field">
                            <label>Finca</label>
                            <input type="text" value="@nombreFinca" readonly>
                        </div>
                        <div class="ee-field">
                            <label>Propietario</label>
                            <input type="text" value="@propietario" readonly>
                        </div>
                        <div class="ee-field span-2">
                            <label>Ubicación</label>
                            <input type="text" value="@ubicacion" readonly>
                        </div>
                    </div>

                    <div class="ee-divider">
                        <i class="fa-solid fa-leaf"></i> Características verificadas en campo
                    </div>

                    <div class="ee-form-grid">

                        <!-- Hectáreas -->
                        <div class="ee-field">
                            <label for="ee-hectareas">
                                Hectáreas verificadas <span class="req">*</span>
                                <span class="orig-tag">Orig: @cHectareas ha</span>
                            </label>
                            <input type="number" id="ee-hectareas"
                                   value="@cHectareas"
                                   step="0.01" min="0.01"
                                   aria-describedby="ee-hectareas-err">
                            <span class="ee-orig-val" id="ee-hectareas-orig" role="status"></span>
                            <span class="ee-field-error" id="ee-hectareas-err" role="alert">
                                <i class="fa-solid fa-triangle-exclamation"></i>
                                Las hectáreas deben ser un número mayor a 0.
                            </span>
                        </div>

                        <!-- Tipo de vegetación -->
                        <div class="ee-field">
                            <label for="ee-vegetacion">
                                Tipo de vegetación <span class="req">*</span>
                                <span class="orig-tag">Orig: @(etiqVeg.ContainsKey(cVegetacion) ? etiqVeg[cVegetacion] : cVegetacion)</span>
                            </label>
                            <select id="ee-vegetacion" aria-describedby="ee-vegetacion-err">
                                <option value="">Seleccione...</option>
                                @foreach (var opt in optsVeg) {
                                    if (opt.Item1 == cVegetacion) {
                                        <option value="@opt.Item1" selected="selected">@opt.Item2</option>
                                    } else {
                                        <option value="@opt.Item1">@opt.Item2</option>
                                    }
                                }
                            </select>
                            <span class="ee-orig-val" id="ee-vegetacion-orig" role="status"></span>
                            <span class="ee-field-error" id="ee-vegetacion-err" role="alert">
                                <i class="fa-solid fa-triangle-exclamation"></i>
                                Seleccione el tipo de vegetación.
                            </span>
                        </div>

                        <!-- Pendiente -->
                        <div class="ee-field">
                            <label for="ee-pendiente">
                                Pendiente del terreno <span class="req">*</span>
                                <span class="orig-tag">Orig: @(etiqPen.ContainsKey(cPendiente) ? etiqPen[cPendiente] : cPendiente)</span>
                            </label>
                            <select id="ee-pendiente" aria-describedby="ee-pendiente-err">
                                <option value="">Seleccione...</option>
                                @foreach (var opt in optsPen) {
                                    if (opt.Item1 == cPendiente) {
                                        <option value="@opt.Item1" selected="selected">@opt.Item2</option>
                                    } else {
                                        <option value="@opt.Item1">@opt.Item2</option>
                                    }
                                }
                            </select>
                            <span class="ee-orig-val" id="ee-pendiente-orig" role="status"></span>
                            <span class="ee-field-error" id="ee-pendiente-err" role="alert">
                                <i class="fa-solid fa-triangle-exclamation"></i>
                                Seleccione el tipo de pendiente.
                            </span>
                        </div>

                        <!-- Recursos hídricos -->
                        <div class="ee-field">
                            <label for="ee-recursos">
                                Recursos hídricos <span class="req">*</span>
                                <span class="orig-tag">Orig: @(etiqRec.ContainsKey(cRecursos) ? etiqRec[cRecursos] : cRecursos)</span>
                            </label>
                            <select id="ee-recursos" aria-describedby="ee-recursos-err">
                                <option value="">Seleccione...</option>
                                @foreach (var opt in optsRec) {
                                    if (opt.Item1 == cRecursos) {
                                        <option value="@opt.Item1" selected="selected">@opt.Item2</option>
                                    } else {
                                        <option value="@opt.Item1">@opt.Item2</option>
                                    }
                                }
                            </select>
                            <span class="ee-orig-val" id="ee-recursos-orig" role="status"></span>
                            <span class="ee-field-error" id="ee-recursos-err" role="alert">
                                <i class="fa-solid fa-triangle-exclamation"></i>
                                Seleccione los recursos hídricos.
                            </span>
                        </div>

                    </div>

                    <!-- Uso de suelo -->
                    <div class="ee-divider">
                        <i class="fa-solid fa-map"></i> Uso de suelo
                        <span style="font-weight:400;text-transform:none;font-size:.75rem;letter-spacing:0;">(selección múltiple)</span>
                    </div>
                    <div class="ee-check-grid">
                        @foreach (var uso in usoSueloOpts) {
                            var esMarcado = usoSueloActual.Contains(uso.Item1);
                            <label class="ee-check-item @(esMarcado ? "marcado" : "")"
                                   data-valor="@uso.Item1"
                                   onclick="eeOnUsoSuelo('@uso.Item1', this)">
                                <input type="checkbox" value="@uso.Item1" @(esMarcado ? "checked" : "")>
                                <div class="ee-check-box"></div>
                                <span class="ee-check-label">@uso.Item2</span>
                            </label>
                        }
                    </div>

                </div>
            </div>

            <!-- ── 3. DATOS DE LA VISITA ── -->
            <div class="ee-panel">
                <div class="ee-panel-header">
                    <h2><i class="fa-solid fa-calendar-check"></i> Datos de la Visita</h2>
                </div>
                <div class="ee-panel-body">
                    <div class="ee-form-grid">

                        <!-- Fecha -->
                        <div class="ee-field">
                            <label for="ee-fecha-visita">
                                Fecha de visita <span class="req">*</span>
                                <span class="orig-tag">Orig: @cFechaVisita</span>
                            </label>
                            <input type="date" id="ee-fecha-visita"
                                   value="@cFechaVisita"
                                   aria-describedby="ee-fecha-visita-err">
                            <span class="ee-orig-val" id="ee-fecha-visita-orig" role="status"></span>
                            <span class="ee-field-error" id="ee-fecha-visita-err" role="alert">
                                <i class="fa-solid fa-triangle-exclamation"></i>
                                La fecha de visita debe ser hoy o posterior.
                            </span>
                        </div>

                        <!-- Hora -->
                        <div class="ee-field">
                            <label for="ee-hora-visita">
                                Hora de inicio
                                <span class="orig-tag">Orig: @cHoraVisita</span>
                            </label>
                            <input type="time" id="ee-hora-visita" value="@cHoraVisita">
                            <span class="ee-orig-val" id="ee-hora-visita-orig" role="status"></span>
                        </div>

                        <!-- Observaciones -->
                        <div class="ee-field span-2">
                            <label for="ee-observaciones">
                                Observaciones técnicas <span class="req">*</span>
                                <span style="font-weight:400;text-transform:none;font-size:.72rem;color:var(--gris-medio);letter-spacing:0;">(mín. 15 caracteres)</span>
                            </label>
                            <textarea id="ee-observaciones"
                                      rows="4"
                                      aria-describedby="ee-observaciones-err">@cObservaciones</textarea>
                            <span class="ee-orig-val" id="ee-observaciones-orig" role="status"></span>
                            <span class="ee-field-error" id="ee-observaciones-err" role="alert">
                                <i class="fa-solid fa-triangle-exclamation"></i>
                                Las observaciones son obligatorias (mín. 15 caracteres).
                            </span>
                        </div>

                    </div>
                </div>
            </div>

            <!-- ===== ACCIONES ===== -->
            <div class="ee-acciones">
                <button class="btn btn-outline" onclick="eeConfirmarSalir()">
                    <i class="fa-solid fa-xmark"></i> Cancelar
                </button>
                <div class="ee-acciones-right">
                    <button class="btn btn-outline"
                            onclick="location.href='@Url.Action("EvaluacionesDetalle","IngForestal", new { id = evalId })'">
                        <i class="fa-solid fa-eye"></i> Ver Detalle
                    </button>
                    <button class="btn btn-primary" onclick="eeGuardar()">
                        <i class="fa-solid fa-floppy-disk"></i> Guardar Cambios
                    </button>
                </div>
            </div>

        </div><!-- /columna principal -->

        <!-- ══════ ASIDE ══════ -->
        <div class="ee-aside">

            <!-- Cálculo estimado -->
            <div class="ee-calculo-panel">
                <div class="ee-calculo-header">
                    <p>Pago mensual estimado</p>
                    <div class="ee-calculo-monto" id="ee-calculo-monto">₡0</div>
                    <div class="ee-calculo-sub">Se actualiza en tiempo real</div>
                </div>
                <div class="ee-calculo-body">
                    <div class="ee-calculo-fila">
                        <span class="ee-calculo-fila-label">Monto base</span>
                        <span class="ee-calculo-fila-val" id="ee-calc-base">₡0</span>
                    </div>
                    <div class="ee-calculo-fila">
                        <span class="ee-calculo-fila-label">Ajuste vegetación</span>
                        <span class="ee-calculo-fila-val" id="ee-calc-veg">0%</span>
                    </div>
                    <div class="ee-calculo-fila">
                        <span class="ee-calculo-fila-label">Ajuste pendiente</span>
                        <span class="ee-calculo-fila-val" id="ee-calc-pen">0%</span>
                    </div>
                    <div class="ee-calculo-fila">
                        <span class="ee-calculo-fila-label">Ajuste recursos</span>
                        <span class="ee-calculo-fila-val" id="ee-calc-rec">0%</span>
                    </div>
                    <div class="ee-calculo-fila">
                        <span class="ee-calculo-fila-label">Total ajustes</span>
                        <span class="ee-calculo-fila-val positivo" id="ee-calc-ajuste">₡0</span>
                    </div>
                    <div class="ee-calculo-fila" style="border-top:2px solid var(--borde);margin-top:4px;padding-top:10px;">
                        <span class="ee-calculo-fila-label" style="color:var(--verde-bosque);font-weight:700;">Total mensual</span>
                        <span class="ee-calculo-fila-val total" id="ee-calc-total">₡0</span>
                    </div>
                </div>
                <p class="ee-calculo-nota">Estimación referencial · Tope de ajustes: 40%</p>
            </div>

            <!-- Acciones rápidas -->
            <div class="ee-aside-acciones">
                <h3><i class="fa-solid fa-bolt"></i> Acciones</h3>
                <button class="btn btn-primary" onclick="eeGuardar()"
                        style="justify-content:center;">
                    <i class="fa-solid fa-floppy-disk"></i> Guardar Cambios
                </button>
                <button class="btn btn-outline"
                        onclick="location.href='@Url.Action("EvaluacionesDetalle","IngForestal", new { id = evalId })'"
                        style="justify-content:center;">
                    <i class="fa-solid fa-eye"></i> Ver Detalle
                </button>
                <button class="btn btn-outline"
                        onclick="location.href='@Url.Action("EvaluacionesPendientes","IngForestal")'"
                        style="justify-content:center;">
                    <i class="fa-solid fa-list"></i> Ver Evaluaciones
                </button>
            </div>

        </div><!-- /aside -->

    </div><!-- /ee-body -->

</div><!-- /tecnico-dashboard -->

<!-- ===== MODAL: CONFIRMAR DESCARTE ===== -->
<div class="ee-modal-overlay" id="ee-modal-overlay"
     role="dialog" aria-modal="true" aria-labelledby="ee-modal-titulo">
    <div class="ee-modal">
        <div class="ee-modal-body">
            <div class="ee-modal-icon">⚠️</div>
            <h3 id="ee-modal-titulo">¿Descartar cambios?</h3>
            <p>Tiene cambios sin guardar en esta evaluación. Si sale ahora, se perderán todos los cambios realizados.</p>
        </div>
        <div class="ee-modal-footer">
            <button class="btn btn-outline" onclick="eeCerrarModal()">
                <i class="fa-solid fa-arrow-left"></i> Seguir editando
            </button>
            <button class="btn" onclick="eeDescartarCambios()"
                    style="background:var(--rojo);color:var(--blanco);">
                <i class="fa-solid fa-trash"></i> Descartar y salir
            </button>
        </div>
    </div>
</div>

<!-- ===== TOAST ===== -->
<div class="td-toast" id="ee-toast" role="alert" aria-live="polite">
    <i class="fa-solid fa-circle-check"></i>
    <span id="ee-toast-msg">Cambios guardados.</span>
</div>

@section Scripts {
    <script src="~/js/ingforestal/evaluaciones-editar.js" asp-append-version="true"></script>
}
