                        </td>
                        <td>Turrialba, Cartago</td>
                        <td>22.00 ha</td>
                        <td>Bosque Primario</td>
                        <td><span class="chip chip-pendiente">● Pendiente</span></td>
                        <td>
                            <div data-fecha-sol="2026-03-05">
                                <span class="ep-espera">—</span>
                            </div>
                        </td>
                        <td><span class="ep-prioridad alta"><i class="fa-solid fa-circle-exclamation"></i> Alta</span></td>
                        <td>
                            <button class="btn-icon" title="Ver detalle" onclick="epVerDetalle(1)">
                                <i class="fa-solid fa-eye"></i>
                            </button>
                            <button class="btn-icon" title="Iniciar evaluación"
                                    onclick="epAbrirModal(1,'Hacienda El Roble','Manuel Araya','Turrialba, Cartago','22.00','Bosque Primario')">
                                <i class="fa-solid fa-play"></i>
                            </button>
                        </td>
                    </tr>

