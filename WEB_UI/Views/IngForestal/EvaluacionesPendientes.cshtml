@{
    ViewData["Title"] = "Evaluaciones Pendientes - Ingeniero Forestal";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/ingforestal/dashboard.css"                   asp-append-version="true" />
    <link rel="stylesheet" href="~/css/ingforestal/evaluaciones-pendientes.css"     asp-append-version="true" />
}

<div class="tecnico-dashboard">

    <!-- ===== BREADCRUMB ===== -->
    <nav class="ep-breadcrumb" aria-label="Ruta de navegación">
        <a href="@Url.Action("Index", "IngForestal")">
            <i class="fa-solid fa-house-chimney"></i> Dashboard
        </a>
        <span class="ep-breadcrumb-sep"><i class="fa-solid fa-chevron-right"></i></span>
        <span>Evaluaciones Pendientes</span>
    </nav>

    <!-- ===== PAGE HEADER ===== -->
    <div class="ep-page-header">
        <div>
            <h1>
                <i class="fa-solid fa-clipboard-list" style="color:var(--verde-claro);font-size:1.4rem;"></i>
                Evaluaciones Pendientes
            </h1>
            <p>Solicitudes asignadas que aún no han iniciado su proceso de evaluación técnica.</p>
        </div>
        <div class="ep-header-actions">
            <button class="btn btn-outline" onclick="location.href='@Url.Action("Index","IngForestal")'">
                <i class="fa-solid fa-arrow-left"></i> Dashboard
            </button>
        </div>
    </div>

    <!-- ===== STATS RÁPIDAS ===== -->
    <div class="ep-stats">
        <div class="ep-stat-card rojo">
            <div class="ep-stat-icon">🔴</div>
            <div class="ep-stat-info">
                <div class="ep-stat-label">Prioridad Alta</div>
                <div class="ep-stat-value">3</div>
            </div>
        </div>
        <div class="ep-stat-card amarillo">
            <div class="ep-stat-icon">🟡</div>
            <div class="ep-stat-info">
                <div class="ep-stat-label">Prioridad Media</div>
                <div class="ep-stat-value">2</div>
            </div>
        </div>
        <div class="ep-stat-card">
            <div class="ep-stat-icon">🟢</div>
            <div class="ep-stat-info">
                <div class="ep-stat-label">Prioridad Baja</div>
                <div class="ep-stat-value">3</div>
            </div>
        </div>
        <div class="ep-stat-card azul">
            <div class="ep-stat-icon">📐</div>
            <div class="ep-stat-info">
                <div class="ep-stat-label">Total Hectáreas</div>
                <div class="ep-stat-value">148</div>
            </div>
        </div>
    </div>

    <!-- ===== PANEL PRINCIPAL ===== -->
    <div class="ep-panel">

        <div class="ep-panel-header">
            <h2><i class="fa-solid fa-hourglass-half"></i> Cola de Evaluaciones</h2>
            <span style="font-size:.8rem;color:var(--gris-medio);" id="ep-pag-info">Cargando...</span>
        </div>

        <!-- Filtros -->
        <div class="ep-filtros">
            <div class="ep-search-wrap">
                <span class="ep-search-icon"><i class="fa-solid fa-magnifying-glass"></i></span>
                <input type="text" id="ep-buscador"
                       placeholder="Buscar por finca, propietario, cantón..."
                       oninput="epFiltrar()" aria-label="Buscar evaluaciones">
            </div>
            <select class="ep-select" id="ep-filtro-veg" onchange="epFiltrar()" aria-label="Filtrar por vegetación">
                <option value="">Toda vegetación</option>
                <option value="bosque-primario">Bosque Primario</option>
                <option value="bosque-secundario">Bosque Secundario</option>
                <option value="plantacion-forestal">Plantación Forestal</option>
                <option value="pasto">Pasto</option>
            </select>
            <select class="ep-select" id="ep-filtro-pri" onchange="epFiltrar()" aria-label="Filtrar por prioridad">
                <option value="">Toda prioridad</option>
                <option value="alta">Alta (&ge;14 días)</option>
                <option value="media">Media (7–13 días)</option>
                <option value="baja">Baja (&lt;7 días)</option>
            </select>
            <select class="ep-select" id="ep-orden" onchange="epFiltrar()" aria-label="Ordenar">
                <option value="espera-desc">Mayor espera</option>
                <option value="fecha-desc">Más recientes</option>
                <option value="fecha-asc">Más antiguas</option>
                <option value="nombre-asc">Finca A–Z</option>
                <option value="hectareas-desc">Mayor hectáreas</option>
            </select>
            <button class="ep-btn-limpiar" onclick="epLimpiarFiltros()" title="Limpiar filtros">
                <i class="fa-solid fa-xmark"></i> Limpiar
            </button>
        </div>

        <!-- Tabla -->
        <div class="ep-table-wrap">
            <table class="ep-table" aria-label="Evaluaciones pendientes">
                <thead>
                    <tr>
                        <th>Finca / Propietario</th>
                        <th>Ubicación</th>
                        <th>Hectáreas</th>
                        <th>Tipo de Vegetación</th>
                        <th>Estado</th>
                        <th>En espera</th>
                        <th>Prioridad</th>
                        <th class="no-sort">Acciones</th>
                    </tr>
                </thead>
                <tbody id="ep-tbody">

                    <!-- ── FILA 1 — Alta prioridad ── -->
