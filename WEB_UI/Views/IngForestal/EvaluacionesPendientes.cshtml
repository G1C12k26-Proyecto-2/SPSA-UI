<!-- ===== MODAL: INICIAR EVALUACIÓN ===== -->
<div class="ep-modal-overlay" id="ep-modal-overlay"
     role="dialog" aria-modal="true" aria-labelledby="ep-modal-titulo">
    <div class="ep-modal">
        <div class="ep-modal-head">
            <h3 id="ep-modal-titulo">
                <i class="fa-solid fa-play"></i> Iniciar Evaluación Técnica
            </h3>
            <button class="ep-modal-close" onclick="epCerrarModal()" aria-label="Cerrar">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>
        <div class="ep-modal-body">
            <p style="font-size:.9rem;color:var(--gris-medio);margin:0 0 16px;">
                ¿Confirma que desea cambiar el estado de esta solicitud a <strong>"En Proceso"</strong>?
                Esta acción quedará registrada en el sistema de auditoría.
            </p>
            <div class="ep-modal-detalle">
                <strong>Finca:</strong> <span id="ep-modal-finca">—</span><br>
                <strong>Propietario:</strong> <span id="ep-modal-prop">—</span><br>
                <strong>Ubicación:</strong> <span id="ep-modal-ubic">—</span><br>
                <strong>Hectáreas:</strong> <span id="ep-modal-hectareas">—</span><br>
                <strong>Vegetación:</strong> <span id="ep-modal-veg">—</span>
            </div>
            <div class="ep-modal-aviso">
                <i class="fa-solid fa-circle-info" style="flex-shrink:0;margin-top:2px;"></i>
                Al iniciar la evaluación podrá acceder al formulario de visita técnica para registrar los datos observados en campo.
            </div>
        </div>
        <div class="ep-modal-footer">
            <button class="btn btn-outline" onclick="epCerrarModal()">
                <i class="fa-solid fa-xmark"></i> Cancelar
            </button>
            <button class="btn btn-primary" onclick="epConfirmarIniciar()">
                <i class="fa-solid fa-play"></i> Sí, iniciar
            </button>
        </div>
    </div>
</div>

<!-- ===== TOAST ===== -->
<div class="td-toast" id="ep-toast" role="alert" aria-live="polite">
    <i class="fa-solid fa-circle-check"></i>
    <span id="ep-toast-msg">Acción realizada.</span>
</div>

@section Scripts {
    <script src="~/js/ingforestal/evaluaciones-pendientes.js" asp-append-version="true"></script>
}
