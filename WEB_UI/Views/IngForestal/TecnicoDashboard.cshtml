@{
    ViewData["Title"] = "Dashboard - Ingeniero Forestal";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/ingforestal/dashboard.css" asp-append-version="true" />
}

<div class="IngForestal-dashboard">

    <!-- ===== HEADER ===== -->
    <div class="td-header">
        <div class="td-header-left">
            <h1>🌿 Panel del Ingeniero Forestal</h1>
            <p>Bienvenido, <strong>Ing. Carlos Pérez</strong> — @DateTime.Now.ToString("dddd, dd 'de' MMMM 'de' yyyy")</p>
        </div>
        <span class="td-badge-rol">
            <i class="fa-solid fa-hard-hat"></i>&nbsp;Ingeniero Forestal
        </span>
    </div>

    <!-- ===== TARJETAS DE RESUMEN ===== -->
    <div class="td-stats">
        <div class="td-stat-card">
            <div class="td-stat-icon">📋</div>
            <div class="td-stat-info">
                <div class="td-stat-label">Pendientes</div>
                <div class="td-stat-value" id="cnt-pendientes">8</div>
                <div class="td-stat-sub">Esperan revisión</div>
            </div>
        </div>
        <div class="td-stat-card amarillo">
            <div class="td-stat-icon">🔄</div>
            <div class="td-stat-info">
                <div class="td-stat-label">En Proceso</div>
                <div class="td-stat-value" id="cnt-proceso">3</div>
                <div class="td-stat-sub">Evaluación activa</div>
            </div>
        </div>
        <div class="td-stat-card">
            <div class="td-stat-icon">✅</div>
            <div class="td-stat-info">
                <div class="td-stat-label">Aprobadas</div>
                <div class="td-stat-value" id="cnt-aprobadas">24</div>
                <div class="td-stat-sub">Este mes: 6</div>
            </div>
        </div>
        <div class="td-stat-card rojo">
            <div class="td-stat-icon">❌</div>
            <div class="td-stat-info">
                <div class="td-stat-label">Rechazadas</div>
                <div class="td-stat-value" id="cnt-rechazadas">4</div>
                <div class="td-stat-sub">Requieren notificación</div>
            </div>
        </div>
    </div>

    <!-- ===== CUERPO PRINCIPAL ===== -->
    <div class="td-body">

        <!-- TABLA DE SOLICITUDES -->
        <div class="td-panel">
            <div class="td-panel-header">
                <h2><i class="fa-solid fa-list-check"></i> Solicitudes Técnicas</h2>
                <button class="btn btn-primary btn-sm" onclick="location.href='@Url.Action("Agenda", "IngForestal")'">
                    <i class="fa-solid fa-calendar-plus"></i> Ver Agenda
                </button>
            </div>

            <!-- Filtros -->
            <div class="td-filtros">
                <div class="td-search-wrap">
                    <span class="td-search-icon"><i class="fa-solid fa-magnifying-glass"></i></span>
                    <input type="text" id="buscador" placeholder="Buscar finca, dueño, cantón..." oninput="filtrarTabla()">
                </div>
                <select class="td-select" id="filtroEstado" onchange="filtrarTabla()">
                    <option value="">Todos los estados</option>
                    <option value="pendiente">Pendiente</option>
                    <option value="proceso">En Proceso</option>
                    <option value="aprobada">Aprobada</option>
                    <option value="rechazada">Rechazada</option>
                </select>
                <select class="td-select" id="filtroOrden" onchange="filtrarTabla()">
                    <option value="fecha-desc">Más recientes</option>
                    <option value="fecha-asc">Más antiguas</option>
                    <option value="nombre-asc">Nombre A–Z</option>
                    <option value="hectareas-desc">Mayor hectáreas</option>
                </select>
            </div>

            <!-- Tabla -->
            <div class="td-table-wrap">
                <table class="td-table" id="tablaSolicitudes">
                    <thead>
                        <tr>
                            <th>Finca / Propietario</th>
                            <th>Ubicación</th>
                            <th>Hectáreas</th>
                            <th>Tipo de Vegetación</th>
                            <th>Estado</th>
                            <th>Fecha Solicitud</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody id="cuerpoTabla">
                        <tr data-estado="pendiente" data-nombre="Finca Los Robles" data-fecha="2026-03-18" data-hectareas="12.5">
                            <td>
                                <div class="td-finca-name">Finca Los Robles</div>
                                <div class="td-finca-loc">José Ángel Mora</div>
                            </td>
                            <td>Turrialba, Cartago</td>
                            <td>12.50 ha</td>
                            <td>Bosque Secundario</td>
                            <td><span class="chip chip-pendiente">Pendiente</span></td>
                            <td>18/03/2026</td>
                            <td>
                                <button class="btn-icon" title="Ver detalle" onclick="verDetalle(1)">
                                    <i class="fa-solid fa-eye"></i>
                                </button>
                                <button class="btn-icon" title="Iniciar evaluación"
                                        onclick="abrirModalProceso(1,'Finca Los Robles','José Ángel Mora')">
                                    <i class="fa-solid fa-play"></i>
                                </button>
                            </td>
                        </tr>
                        <tr data-estado="pendiente" data-nombre="Hacienda Verde" data-fecha="2026-03-15" data-hectareas="28.0">
                            <td>
                                <div class="td-finca-name">Hacienda Verde</div>
                                <div class="td-finca-loc">María Solano Vega</div>
                            </td>
                            <td>Sarapiquí, Heredia</td>
                            <td>28.00 ha</td>
                            <td>Bosque Primario</td>
                            <td><span class="chip chip-pendiente">Pendiente</span></td>
                            <td>15/03/2026</td>
                            <td>
                                <button class="btn-icon" title="Ver detalle" onclick="verDetalle(2)">
                                    <i class="fa-solid fa-eye"></i>
                                </button>
                                <button class="btn-icon" title="Iniciar evaluación"
                                        onclick="abrirModalProceso(2,'Hacienda Verde','María Solano Vega')">
                                    <i class="fa-solid fa-play"></i>
                                </button>
                            </td>
                        </tr>
                        <tr data-estado="proceso" data-nombre="Finca El Cedro" data-fecha="2026-03-10" data-hectareas="9.75">
                            <td>
                                <div class="td-finca-name">Finca El Cedro</div>
                                <div class="td-finca-loc">Roberto Chaves</div>
                            </td>
                            <td>Pérez Zeledón, San José</td>
                            <td>9.75 ha</td>
                            <td>Plantación Forestal</td>
                            <td><span class="chip chip-proceso">En Proceso</span></td>
                            <td>10/03/2026</td>
                            <td>
                                <button class="btn-icon" title="Ver detalle" onclick="verDetalle(3)">
                                    <i class="fa-solid fa-eye"></i>
                                </button>
                                <button class="btn-icon" title="Continuar evaluación"
                                        onclick="location.href='@Url.Action("Realizar", "IngForestal")?id=3'">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                </button>
                            </td>
                        </tr>
                        <tr data-estado="aprobada" data-nombre="Lote Montañés" data-fecha="2026-03-05" data-hectareas="45.0">
                            <td>
                                <div class="td-finca-name">Lote Montañés</div>
                                <div class="td-finca-loc">Ana Chinchilla</div>
                            </td>
                            <td>Tarrazú, San José</td>
                            <td>45.00 ha</td>
                            <td>Bosque Primario</td>
                            <td><span class="chip chip-aprobada">Aprobada</span></td>
                            <td>05/03/2026</td>
                            <td>
                                <button class="btn-icon" title="Ver detalle" onclick="verDetalle(4)">
                                    <i class="fa-solid fa-eye"></i>
                                </button>
                            </td>
                        </tr>
                        <tr data-estado="rechazada" data-nombre="Finca San Marcos" data-fecha="2026-02-28" data-hectareas="5.0">
                            <td>
                                <div class="td-finca-name">Finca San Marcos</div>
                                <div class="td-finca-loc">Luis Blanco</div>
                            </td>
                            <td>Alajuela, Alajuela</td>
                            <td>5.00 ha</td>
                            <td>Pasto</td>
                            <td><span class="chip chip-rechazada">Rechazada</span></td>
                            <td>28/02/2026</td>
                            <td>
                                <button class="btn-icon" title="Ver detalle" onclick="verDetalle(5)">
                                    <i class="fa-solid fa-eye"></i>
                                </button>
                            </td>
                        </tr>
                    </tbody>
                </table>

                <!-- Estado vacío -->
                <div class="td-empty" id="estadoVacio" style="display:none;">
                    <div class="td-empty-icon">🔍</div>
                    <p>No se encontraron solicitudes con esos criterios.</p>
                </div>
            </div>

            <!-- Paginación -->
            <div class="td-paginacion">
                <span id="pag-info">Mostrando 5 de 39 solicitudes</span>
                <div class="td-pag-btns">
                    <button class="td-pag-btn" title="Anterior"><i class="fa-solid fa-chevron-left"></i></button>
                    <button class="td-pag-btn activo">1</button>
                    <button class="td-pag-btn">2</button>
                    <button class="td-pag-btn">3</button>
                    <button class="td-pag-btn" title="Siguiente"><i class="fa-solid fa-chevron-right"></i></button>
                </div>
            </div>
        </div>

        <!-- PANEL DERECHO -->
        <div style="display:flex;flex-direction:column;gap:24px;">

            <!-- Agenda próxima -->
            <div class="td-panel">
                <div class="td-panel-header">
                    <h2><i class="fa-solid fa-calendar-days"></i> Agenda Próxima</h2>
                    <a href="@Url.Action("Agenda","IngForestal")" class="btn btn-outline btn-sm">Ver todo</a>
                </div>
                <div class="td-panel-body">
                    <div class="td-agenda-list">
                        <div class="td-agenda-item" onclick="location.href='@Url.Action("Detalle", "IngForestal")?id=1'">
                            <div class="td-agenda-fecha">
                                <div class="td-agenda-dia">23</div>
                                <div class="td-agenda-mes">Mar</div>
                            </div>
                            <div class="td-agenda-info">
                                <div class="td-agenda-titulo">Finca Los Robles</div>
                                <div class="td-agenda-loc"><i class="fa-solid fa-location-dot"></i> Turrialba, Cartago</div>
                            </div>
                            <div class="td-agenda-hora">08:00 AM</div>
                        </div>
                        <div class="td-agenda-item" onclick="location.href='@Url.Action("Detalle", "IngForestal")?id=2'">
                            <div class="td-agenda-fecha">
                                <div class="td-agenda-dia">25</div>
                                <div class="td-agenda-mes">Mar</div>
                            </div>
                            <div class="td-agenda-info">
                                <div class="td-agenda-titulo">Hacienda Verde</div>
                                <div class="td-agenda-loc"><i class="fa-solid fa-location-dot"></i> Sarapiquí, Heredia</div>
                            </div>
                            <div class="td-agenda-hora">10:30 AM</div>
                        </div>
                        <div class="td-agenda-item" onclick="location.href='@Url.Action("Detalle", "IngForestal")?id=3'">
                            <div class="td-agenda-fecha">
                                <div class="td-agenda-dia">28</div>
                                <div class="td-agenda-mes">Mar</div>
                            </div>
                            <div class="td-agenda-info">
                                <div class="td-agenda-titulo">Lote El Pinar</div>
                                <div class="td-agenda-loc"><i class="fa-solid fa-location-dot"></i> San Ramón, Alajuela</div>
                            </div>
                            <div class="td-agenda-hora">07:00 AM</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Resumen del mes -->
            <div class="td-panel">
                <div class="td-panel-header">
                    <h2><i class="fa-solid fa-chart-pie"></i> Resumen del Mes</h2>
                </div>
                <div class="td-mini-stats">
                    <div>
                        <div class="td-mini-row">
                            <span class="td-mini-label"><i class="fa-solid fa-tree"></i> Fincas evaluadas</span>
                            <span class="td-mini-val">14 / 20</span>
                        </div>
                        <div class="td-progress-bar-wrap" style="margin-top:8px;">
                            <div class="td-progress-bar" style="width:70%;"></div>
                        </div>
                    </div>
                    <div class="td-mini-row">
                        <span class="td-mini-label"><i class="fa-solid fa-ruler-combined"></i> Ha. evaluadas</span>
                        <span class="td-mini-val">218.5 ha</span>
                    </div>
                    <div class="td-mini-row">
                        <span class="td-mini-label"><i class="fa-solid fa-check-circle" style="color:var(--verde-claro);"></i> Tasa aprobación</span>
                        <span class="td-mini-val">85%</span>
                    </div>
                    <div class="td-mini-row">
                        <span class="td-mini-label"><i class="fa-solid fa-clock" style="color:var(--amarillo);"></i> Tiempo prom.</span>
                        <span class="td-mini-val">3.2 días</span>
                    </div>
                    <a href="@Url.Action("Pendientes","Evaluaciones")" class="btn btn-primary" style="margin-top:4px;justify-content:center;">
                        <i class="fa-solid fa-clipboard-list"></i> Ver Evaluaciones
                    </a>
                </div>
            </div>

        </div>
    </div><!-- /td-body -->

</div><!-- /tecnico-dashboard -->

<!-- ===== MODAL: Cambiar a "En Proceso" ===== -->
<div class="td-modal-overlay" id="modalProceso">
    <div class="td-modal" role="dialog" aria-modal="true" aria-labelledby="modal-titulo">
        <div class="td-modal-icon">🔄</div>
        <h3 id="modal-titulo">Iniciar evaluación técnica</h3>
        <p>¿Desea cambiar el estado de esta solicitud a <strong>"En Proceso"</strong>?
           Esta acción quedará registrada en la auditoría del sistema.</p>
        <div class="td-modal-detail">
            <strong>Finca:</strong> <span id="modal-finca">—</span><br>
            <strong>Propietario:</strong> <span id="modal-propietario">—</span>
        </div>
        <div class="td-modal-actions">
            <button class="btn btn-outline" onclick="cerrarModal()">Cancelar</button>
            <button class="btn btn-primary" onclick="confirmarIniciarProceso()">
                <i class="fa-solid fa-play"></i> Sí, iniciar
            </button>
        </div>
    </div>
</div>

<!-- ===== TOAST ===== -->
<div class="td-toast" id="toast" role="alert" aria-live="polite">
    <i class="fa-solid fa-circle-check"></i>
    <span id="toast-msg">Acción realizada correctamente.</span>
</div>

@section Scripts {
    <script src="~/js/ingforestal/dashboard.js" asp-append-version="true"></script>
}
